<?xml version="1.0" encoding="utf-8"?>
<chart id="133">
  <P Name="name">TruckMaker/Comparison Block Forces /Comparison Functions </P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">133</P>
  <P Name="ssIdHighWaterMark">46</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">6</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">tire_model_4W_vehicleFrame</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">133</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [alpha_f, alpha_r, Fy, Vx_wheel, Vy_wheel] = tire_model_4W_vehicleFrame(Vec_v, Car_w, delta_f,Toe_angle, CyF, CyR)
%TIRE_MODEL_4W_VEHICLEFRAME
%  Beräknar slipvinklar och lateral forces för ett 4-hjuls fordon
%  
%  Input:
%    Vec_v   - [3x1] Vehicle velocity i vehicle frame [Vx; Vy; Vz]
%    Car_w   - [3x1] Vehicle angular rates i vehicle frame [rollRate; pitchRate; yawRate]
%    delta_f - [2x1] Framhjul styrvinklar [delta_FL; delta_FR] (rad)
%    CyF     - [2x1] Framhjul cornering stiffness per wheel
%    CyR     - [2x1] Bakhjul cornering stiffness per wheel
%
%  Output:
%    alpha_f - [2x1] Slipvinkel framhjul [rad]
%    alpha_r - [2x1] Slipvinkel bakhjul [rad]
%    Fy      - [4x1] Lateral force per wheel [N]
%    Vx_wheel, Vy_wheel - [4x1] Hjulhastigheter i hjulens frame

%% ================= PARAMETERS =================
eps_v  = 0.1;   % min velocity för slipvinkel
g = 9.82;       % gravitation [m/s^2]
load_front_axle = 4805.882;   
load_rear_axle  = 2194.118;   

%% ================= GEOMETRY =================
% Kontaktpunkter i vehicle frame
tire_contact_point_FL = [4.52;  1.05; 0]; 
tire_contact_point_FR = [4.52; -1.05; 0];
tire_contact_point_RL = [0.95;  1.05; 0];
tire_contact_point_RR = [0.95; -1.05; 0];

% Reference point (IMU/vehicle CoM)
Vec_coor = [3.6; 0; 1];

% Vektorer från CoM till hjul
rFL = tire_contact_point_FL - Vec_coor;
rFR = tire_contact_point_FR - Vec_coor;
rRL = tire_contact_point_RL - Vec_coor;
rRR = tire_contact_point_RR - Vec_coor;

%% ================= CONTACT PATCH VELOCITY =================
V_FL = Vec_v + cross(Car_w, rFL);
V_FR = Vec_v + cross(Car_w, rFR);
V_RL = Vec_v + cross(Car_w, rRL);
V_RR = Vec_v + cross(Car_w, rRR);

%% ================= TRANSFORM TO WHEEL FRAME =================
% 2D rotation för framhjul
R_FL = [cos(delta_f(1)), sin(delta_f(1));
       -sin(delta_f(1)), cos(delta_f(1))];

R_FR = [cos(delta_f(2)), sin(delta_f(2));
       -sin(delta_f(2)), cos(delta_f(2))];

% Bakhjul (delta=0)
R_RL = eye(2);
R_RR = eye(2);

% Transformera
V_FL_local = R_FL * V_FL(1:2);
V_FR_local = R_FR * V_FR(1:2);
V_RL_local = R_RL * V_RL(1:2);
V_RR_local = R_RR * V_RR(1:2);


Vx_wheel = [V_FL_local(1); V_FR_local(1); V_RL_local(1); V_RR_local(1)];
Vy_wheel = [V_FL_local(2); V_FR_local(2); V_RL_local(2); V_RR_local(2)];

%% ================= SLIP ANGLES =================
Vx_safe = max(abs(Vx_wheel), eps_v);  % förhindrar division med 0
alpha = atan2(Vy_wheel, Vx_safe);

% Fram och bak separering
alpha_f = alpha(1:2); % - Toe_angle(1:2);
alpha_r = alpha(3:4);% + Toe_angle(3:4).*[1;-1];

%% ================= CORNERING STIFFNESS =================
Cy_FL = CyF(1) * load_front_axle * g / 2;
Cy_FR = CyF(2) * load_front_axle * g / 2;

Cy_RL = CyR(1) * load_rear_axle  * g / 2;
Cy_RR = CyR(2) * load_rear_axle  * g / 2;

Cy = [Cy_FL; Cy_FR; Cy_RL; Cy_RR];

%% ================= LATERAL FORCES =================
Fy = -Cy .* alpha;

end</P>
      </eml>
    </state>
