<?xml version="1.0" encoding="utf-8"?>
<chart id="149">
  <P Name="name">TruckMaker/Two_TRack_Model/MATLAB Function3</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">149</P>
  <P Name="ssIdHighWaterMark">17</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">7</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_5state_4W</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">149</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat,P] = UKF_5state_4W(z,u,Q,R,Ts,sensor_pos,F_wheel_pos,R_wheel_pos)
% UKF for 4-wheel vehicle
% States: x = [vx; vy; wz; CyF; CyR]
% Measurements: z = [ax; ay; vx; vy; wz; wFL; wFR; wRL; wRR]

persistent x Pk
if isempty(x)
    x = [15; 0; 0.05; 4e4; 4e4]; % initial state
end
if isempty(Pk)
    Pk = diag([1 1 0.01 1e6 1e6]);
end

%% Vehicle parameters
m  = 7000;
Jz = 14232.357;
Rw = 0.49;
g  = 9.82;
track = 2.49;

n = length(x); % state dimension

delta = u(1);      % steering input
Fx_in = u(2)/Rw;   % longitudinal force / wheel radius

%% UKF weights (old style)
W0 = 1 - n/3;
Wi = (1-W0)/(2*n);
gamma = sqrt(n/(1-W0));

%% Sigma points
S = chol(Pk,&apos;lower&apos;);
X = zeros(n,2*n+1);
X(:,1) = x;
for i=1:n
    X(:,i+1)   = x + gamma*S(:,i);
    X(:,i+1+n) = x - gamma*S(:,i);
end

%% ------------------- PREDICTION -------------------
X_pred = zeros(n,2*n+1);

for k=1:2*n+1
    vx  = X(1,k);
    vy  = X(2,k);
    wz  = X(3,k);
    CyF = X(4,k);
    CyR = X(5,k);

    Car_v = [vx; vy; 0];
    Car_w = [wx; wy; wz];

    % ---- Wheel velocities at contact patch ----
    V_FL = Car_v + cross(Car_w, F_wheel_pos.FL);
    V_FR = Car_v + cross(Car_w, F_wheel_pos.FR);
    V_RL = Car_v + cross(Car_w, R_wheel_pos.RL);
    V_RR = Car_v + cross(Car_w, R_wheel_pos.RR);

    % ---- Rotate front wheels to wheel frame ----
    R_FL = [ cos(delta)  sin(delta) 0;
            -sin(delta)  cos(delta) 0;
             0           0          1];
    R_FR = R_FL;

    VwfL = R_FL * V_FL;
    VwfR = R_FR * V_FR;

    VwrL = V_RL; % rear wheels no steering
    VwrR = V_RR;

    % ---- Slip angles ----
    alpha_FL = atan2(VwfL(2), VwfL(1));
    alpha_FR = atan2(VwfR(2), VwfR(1));
    alpha_RL = atan2(VwrL(2), VwrL(1));
    alpha_RR = atan2(VwrR(2), VwrR(1));

    % ---- Lateral forces ----
    Fy_FL = -CyF * alpha_FL;
    Fy_FR = -CyF * alpha_FR;
    Fy_RL = -CyR * alpha_RL;
    Fy_RR = -CyR * alpha_RR;

    % Total lateral force &amp; yaw moment
    Fy_total = Fy_FL + Fy_FR + Fy_RL + Fy_RR;
    Mz = F_wheel_pos.FL(1)*Fy_FL + F_wheel_pos.FR(1)*Fy_FR + ...
         R_wheel_pos.RL(1)*Fy_RL + R_wheel_pos.RR(1)*Fy_RR;

    % ---- Dynamics ----
    dvx = Fx_in/m + vy*wz;
    dvy = Fy_total/m - vx*wz;
    dwz = Mz / Jz;

    % Propagate state
    X_pred(:,k) = [vx + Ts*dvx;
                   vy + Ts*dvy;
                   wz + Ts*dwz;
                   CyF;
                   CyR];
end

%% Predicted mean
x_pred = W0*X_pred(:,1);
for k=2:2*n+1
    x_pred = x_pred + Wi*X_pred(:,k);
end

%% Predicted covariance
P_pred = Q;
for k=1:2*n+1
    w = Wi; if k==1, w=W0; end
    dx = X_pred(:,k) - x_pred;
    P_pred = P_pred + w*(dx*dx&apos;);
end

%% ------------------- MEASUREMENT -------------------
m_dim = length(z);
Z = zeros(m_dim,2*n+1);

for k=1:2*n+1
    vx  = X_pred(1,k);
    vy  = X_pred(2,k);
    wz  = X_pred(3,k);
    CyF = X_pred(4,k);
    CyR = X_pred(5,k);

    Car_v = [vx; vy; 0];
    Car_w = [0; 0; wz];

    % Velocity at sensor
    V_sensor = Car_v + cross(Car_w, sensor_pos);

    % Acceleration at sensor (approx)
    ax_s = Fx_in/m + vy*wz;
    ay_s = ( -CyF*(atan2(Car_v(2)+wz*F_wheel_pos.FL(2),Car_v(1))) ...
           -CyF*(atan2(Car_v(2)+wz*F_wheel_pos.FR(2),Car_v(1))) ...
           -CyR*(atan2(Car_v(2)+wz*R_wheel_pos.RL(2),Car_v(1))) ...
           -CyR*(atan2(Car_v(2)+wz*R_wheel_pos.RR(2),Car_v(1))) )/m;
    az_s = 0;

    % Wheel speeds
    wFL = V_FL(1)/Rw;
    wFR = V_FR(1)/Rw;
    wRL = V_RL(1)/Rw;
    wRR = V_RR(1)/Rw;

    Z(:,k) = [ax_s; ay_s; vx; vy; wz; wFL; wFR; wRL; wRR];
end

% Predicted measurement mean
z_pred = W0*Z(:,1);
for k=2:2*n+1
    z_pred = z_pred + Wi*Z(:,k);
end

% Measurement covariance &amp; cross-covariance
S_cov = R;
Pxz   = zeros(n,m_dim);
for k=1:2*n+1
    w = Wi; if k==1, w=W0; end
    dz = Z(:,k) - z_pred;
    dx = X_pred(:,k) - x_pred;
    S_cov = S_cov + w*(dz*dz&apos;);
    Pxz   = Pxz + w*(dx*dz&apos;);
end

% Kalman gain
K = Pxz / (S_cov + 1e-6*eye(m_dim));

% Update
x  = x_pred + K*(z - z_pred);
Pk = P_pred - K*S_cov*K&apos;;

xhat = x;
P    = Pk;

end



%%%%%%%%%%%%%%%%%%%%%%%
function [alpha_f, alpha_r, Ffy, Fry, ...
          VfL, VfR, VrL, VrR] = tire_model_4W( ...
          Car_v, Car_w, delta_f, CyF, CyR)

% ------------------------------------------------------------
% INPUTS
% Car_v   = [vx; vy; vz]      (vehicle body frame)
% Car_w   = [0; 0; wz]        (vehicle body frame)
% delta_f = [delta_L; delta_R] (front steering angles)
% CyF     = [Cy_FL; Cy_FR]
% CyR     = [Cy_RL; Cy_RR]
%
% OUTPUTS
% alpha_f = [alpha_FL; alpha_FR]
% alpha_r = [alpha_RL; alpha_RR]
% Ffy     = [Fy_FL; Fy_FR]
% Fry     = [Fy_RL; Fy_RR]
% VwfL etc = velocities in wheel frame
% ------------------------------------------------------------

%% ================= PARAMETERS =================
R = 0.49;                 % wheel radius
g = 9.82;

load_front_axle = 4805.882;
load_rear_axle  = 2194.118;

%% ================= GEOMETRY =================
% Wheel centers in vehicle body frame
tire_coor_Fl = [4.52;  1.05; 0.49];
tire_coor_FR = [4.52; -1.05; 0.49];
tire_coor_Rl = [0.95;  1.05; 0.49];
tire_coor_RR = [0.95; -1.05; 0.49];

Car_coor = [3.6; 0; 1];

% Position vectors CG → wheel center
rFl = tire_coor_Fl - Car_coor;
rFR = tire_coor_FR - Car_coor;
rRl = tire_coor_Rl - Car_coor;
rRR = tire_coor_RR - Car_coor;

% Move to CONTACT PATCH
rFl = rFl + [0;0;-R];
rFR = rFR + [0;0;-R];
rRl = rRl + [0;0;-R];
rRR = rRR + [0;0;-R];

%% ================= VELOCITIES AT CONTACT =================
VfL = Car_v + cross(Car_w, rFl);
VfR = Car_v + cross(Car_w, rFR);
VrL = Car_v + cross(Car_w, rRl);
VrR = Car_v + cross(Car_w, rRR);

%% ================= ROTATE TO WHEEL FRAME =================
% Front left
R_FL = [ cos(delta_f(1))  -sin(delta_f(1)) 0;
        sin(delta_f(1))  cos(delta_f(1)) 0;
         0                0               1];

% Front right
R_FR = [ cos(delta_f(2))  -sin(delta_f(2)) 0;
       sin(delta_f(2))  cos(delta_f(2)) 0;
         0                0               1];

VfL = R_FL * VfL;
VfR = R_FR * VfR;

% Rear wheels (no steering)
%VrL = VrL;
%VrR = VrR;

%% ================= SLIP ANGLES =================
alpha_FL = atan2(VfL(2), VfL(1)); %- delta_f(1);
alpha_FR = atan2(VfR(2), VfR(1));%- delta_f(2);

alpha_RL = atan2(VrL(2), VrL(1));
alpha_RR = atan2(VrR(2), VrR(1));

alpha_f = [alpha_FL; alpha_FR];
alpha_r = [alpha_RL; alpha_RR];

%% ================= CORNERING STIFFNESS =================
Cy_FL = CyF(1) * load_front_axle * g / 2;
Cy_FR = CyF(2) * load_front_axle * g / 2;

Cy_RL = CyR(1) * load_rear_axle * g/2;
Cy_RR = CyR(2) * load_rear_axle * g/2;

%% ================= LATERAL FORCES =================
Fy_FL = -Cy_FL * alpha_FL;
Fy_FR = -Cy_FR * alpha_FR;

Fy_RL = -Cy_RL * alpha_RL;
Fy_RR = -Cy_RR * alpha_RR;

Ffy = [Fy_FL; Fy_FR];
Fry = [Fy_RL; Fy_RR];

end


</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="xhat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
