  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">276</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function delta = ackerman_angle(delta_l, delta_r)

delta = acot((cot(delta_l) + cot(delta_r))/2);

end</P>
      </eml>
    </state>
    <data SSID="4" name="delta_l">
