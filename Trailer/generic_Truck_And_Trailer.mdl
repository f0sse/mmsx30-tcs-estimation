<?xml version="1.0" encoding="utf-8"?>
<chart id="173">
  <P Name="name">TruckMaker/Two_TRack_Model/Two Track Model</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">173</P>
  <P Name="ssIdHighWaterMark">25</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">9</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_4Wheel</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">173</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat,P_out,Fy_mean,alpha_mean,...
          V_FL_whl,V_FR_whl,V_RL_whl,V_RR_whl] ...
          = UKF_4Wheel(z,u,Q,R,Ts)

persistent x P

%% ================= INIT =================
if isempty(x)
    x = [15; 0; 0.01; 4; 4; 4; 4];
end

if isempty(P)
    P = diag([1 1 0.01 1e4 1e4 1e4 1e4]);
end

n = length(x);
m = length(z);

%% ================= VEHICLE =================
m_car = 7000;
Jz = 14232.357;
lf = 4.52;
lr = 0.95;
R_w = 0.49;
track=2.10;

%% ================= INPUTS =================
delta_FL = u(1);
delta_FR = u(2);
delta_RL = 0;
delta_RR = 0;

Fx_FL = u(5)/R_w;
Fx_FR = u(6)/R_w;
Fx_RL = u(7)/R_w;
Fx_RR = u(8)/R_w;

%% ================= ROTATION MATRICES =================
R_FL = [cos(delta_FL) sin(delta_FL);
       -sin(delta_FL) cos(delta_FL)];

R_FR = [cos(delta_FR) sin(delta_FR);
       -sin(delta_FR) cos(delta_FR)];

R_RL = eye(2);
R_RR = eye(2);

%% ================= GEOMETRY =================
tire_FL = [lf;  1.05; 0];
tire_FR = [lf; -1.05; 0];
tire_RL = [lr;  1.05; 0];
tire_RR = [lr; -1.05; 0];

CoM = [3.6; 0; 1];  % Ändra koor till COM (Jobba i CoG)  

rFL = tire_FL - CoM;
rFR = tire_FR - CoM;
rRL = tire_RL - CoM;
rRR = tire_RR - CoM;

%% ================= UKF =================
W0 = 1 - n/3;
Wi = (1 - W0)/(2*n);
gamma = sqrt(n/(1-W0));

%P = (P+P&apos;)/2 + 1e-9*eye(n); 
S = chol(P,&apos;lower&apos;); %% kolla upp den igen 

X = zeros(n,2*n+1);
X(:,1) = x;

for i=1:n
    X(:,i+1)   = x + gamma*S(:,i);
    X(:,i+1+n) = x - gamma*S(:,i);
end

%% ================= PROPAGATION =================
X_pred = zeros(n,2*n+1);
Fy_sigma = zeros(4,2*n+1);
alpha_sigma = zeros(4,2*n+1);
% R; M; Jz
for k=1:2*n+1

    vx = X(1,k);
    vy = X(2,k);
    r  = X(3,k);

    Cf_FL = X(4,k);
    Cf_FR = X(5,k);
    Cr_RL = X(6,k);
    Cr_RR = X(7,k);

    % ===== FIX 1: korrekt vx_safe =====
    %vx_safe = vx;

    Vc = [vx; vy; 0]; % vehilce Frame 
    omega = [0;0;r];

    V_FL = Vc + cross(omega,rFL);
    V_FR = Vc + cross(omega,rFR);
    V_RL = Vc + cross(omega,rRL);
    V_RR = Vc + cross(omega,rRR);

    V_FL_l = R_FL*V_FL(1:2);
    V_FR_l = R_FR*V_FR(1:2);
    V_RL_l = V_RL(1:2);
    V_RR_l = V_RR(1:2);
    
    %============Side Slip Vinkel på respektiv däck ==================
    alpha_FL = atan2(V_FL_l(2),max(abs(V_FL_l(1)),0.1));
    alpha_FR = atan2(V_FR_l(2),max(abs(V_FR_l(1)),0.1));
    alpha_RL = atan2(V_RL_l(2),max(abs(V_RL_l(1)),0.1));
    alpha_RR = atan2(V_RR_l(2),max(abs(V_RR_l(1)),0.1));


    %===================Forces==============================
    Fy_FL = -Cf_FL*alpha_FL;
    Fy_FR = -Cf_FR*alpha_FR;
    Fy_RL = -Cr_RL*alpha_RL;
    Fy_RR = -Cr_RR*alpha_RR;


    % Transformerta dessa krafter till kroppens FRAME
    F_FL = R_FL&apos;*[Fx_FL;Fy_FL];
    F_FR = R_FR&apos;*[Fx_FR;Fy_FR];
    F_RL = [Fx_RL;Fy_RL];
    F_RR = [Fx_RR;Fy_RR];

    Fx_sum = F_FL(1)+F_FR(1)+F_RL(1)+F_RR(1);
    Fy_sum = F_FL(2)+F_FR(2)+F_RL(2)+F_RR(2);

    dvx = Fx_sum/m_car + vy*r; % andra terma roteradnde koordinat system 
    dvy = Fy_sum/m_car - vx*r; 

%dW = truck.Jinv * (cross(R1, RotW1*F1) + cross(R2, RotW2*F2) 
                    % + cross(R3, F3) + cross(R4, F4));

    % ===== FIX 2: korrekt  eller ej fråga Axel  yaw moment =====
    % !!!!!!!!!!
    Mz = (lf-CoM(1))*(F_FL(2)+F_FR(2)) - (CoM(1)-lr)*(F_RL(2)+F_RR(2)) ... 
        + (track/2)*(F_FR(1)-F_FL(1)) + (track/2)*(F_RR(1)-F_RL(1));
    dr = Mz / Jz;

    X_pred(:,k) = [vx+dvx*Ts;
                   vy+dvy*Ts;
                   r+dr*Ts;
                   Cf_FL;
                   Cf_FR;
                   Cr_RL;
                   Cr_RR];

    Fy_sigma(:,k)    = [F_FL(2);F_FR(2);F_RL(2);F_RR(2)];
    alpha_sigma(:,k) = [alpha_FL;alpha_FR;alpha_RL;alpha_RR];
end

W = [W0 repmat(Wi,1,2*n)];
%x_pred = X_pred*W&apos;;
Fy_mean = Fy_sigma*W&apos;;
alpha_mean = alpha_sigma*W&apos;;
%% Predicted mean
x_pred = W0*X_pred(:,1);
for k=2:2*n+1
    x_pred = x_pred + Wi*X_pred(:,k);
end

%% ================= COVARIANCE =================
% P_pred = Q*Ts;
% for k=1:2*n+1
%     dx = X_pred(:,k)-x_pred;
%     P_pred = P_pred + W(k)*(dx*dx&apos;);
% end

%% Predicted covariance
P_pred = Q*Ts;
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    P_pred = P_pred + w*(dx*dx&apos;);
end
%% ================= MEASUREMENT =================
Z_sigma = zeros(m,2*n+1);

for k=1:2*n+1

    vx = X_pred(1,k);
    vy = X_pred(2,k);
    r  = X_pred(3,k);

    %Cf_FL = X_pred(4,k);
    %Cf_FR = X_pred(5,k);
    %Cr_RL = X_pred(6,k);
    %Cr_RR = X_pred(7,k);


    vx_safe = abs(vx);

    Vc = [vx_safe;vy;0];
    omega = [0;0;r];

    V_FL = Vc + cross(omega,rFL);
    V_FR = Vc + cross(omega,rFR);
    V_RL = Vc + cross(omega,rRL);
    V_RR = Vc + cross(omega,rRR);

    V_FL_l = R_FL*V_FL(1:2);
    V_FR_l = R_FR*V_FR(1:2);
    V_RL_l = V_RL(1:2);
    V_RR_l = V_RR(1:2);

     %============Side Slip Vinkel på respektiv däck ==================
    alpha_FL = atan2(V_FL_l(2),max(abs(V_FL_l(1)),0.1));
    alpha_FR = atan2(V_FR_l(2),max(abs(V_FR_l(1)),0.1));
    alpha_RL = atan2(V_RL_l(2),max(abs(V_RL_l(1)),0.1));
    alpha_RR = atan2(V_RR_l(2),max(abs(V_RR_l(1)),0.1));


    %===================Forces==============================
    Fy_FL = -Cf_FL*alpha_FL;
    Fy_FR = -Cf_FR*alpha_FR;
    Fy_RL = -Cr_RL*alpha_RL;
    Fy_RR = -Cr_RR*alpha_RR;


    % Transformerta dessa krafter till kroppens FRAME
    F_FL = R_FL&apos;*[Fx_FL;Fy_FL];
    F_FR = R_FR&apos;*[Fx_FR;Fy_FR];
    F_RL = [Fx_RL;Fy_RL];
    F_RR = [Fx_RR;Fy_RR];

    Fx_sum = F_FL(1)+F_FR(1)+F_RL(1)+F_RR(1);
    Fy_sum = F_FL(2)+F_FR(2)+F_RL(2)+F_RR(2);

    % ===== FIX 3: hjulhastigheter istället för krafter =====
    w_FL = V_FL_l(1)/R_w;    % Fråga MATS om Long slip och R_w 
    w_FR = V_FR_l(1)/R_w;
    w_RL = V_RL_l(1)/R_w;
    w_RR = V_RR_l(1)/R_w;

    ax = (Fx_sum)/m_car ;
    ay = (Fy_sum)/m_car;

    Z_sigma(:,k) = [ax; ay; vx; vy; r; w_FL; w_FR; w_RL; w_RR];
end

% z_pred = Z_sigma*W&apos;;
% 
% P_zz = R;
% P_xz = zeros(n,m);
% 
% for k=1:2*n+1
%     dz = Z_sigma(:,k)-z_pred;
%     dx = X_pred(:,k)-x_pred;
%     P_zz = P_zz + W(k)*(dz*dz&apos;);
%     P_xz = P_xz + W(k)*(dx*dz&apos;);
% end
% 
% %% ================= UPDATE =================
% K =   P_xz / P_zz;
% x = x_pred + K*(z - z_pred);
% 
% P = P_pred - K*P_zz*K&apos;;

% ===== FIX 4: symmetrisera P =====
%P = (P+P&apos;)/2 + 1e-9*eye(n);

%% Measurement mean
z_pred = W0*Z_sigma(:,1);
for k=2:2*n+1
    z_pred = z_pred + Wi*Z_sigma(:,k);
end

%% Measurement covariance
S_cov = R;
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dz = Z_sigma(:,k) - z_pred;
    S_cov = S_cov + w*(dz*dz&apos;);
end

%% Cross covariance
Pxz = zeros(n,length(z));
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    dz = Z_sigma(:,k) - z_pred;
    Pxz = Pxz + w*(dx*dz&apos;);
end

%% Kalman update
K = Pxz / (S_cov);
x = x_pred + K*(z - z_pred);
P = P_pred - K*S_cov*K&apos;;

%% ================= OUTPUT =================
vx = x(1); vy = x(2); r = x(3);

Vc = [vx;vy;0];
omega = [0;0;r];

V_FL = Vc + cross(omega,rFL);
V_FR = Vc + cross(omega,rFR);
V_RL = Vc + cross(omega,rRL);
V_RR = Vc + cross(omega,rRR);

V_FL_whl = R_FL*V_FL(1:2);
V_FR_whl = R_FR*V_FR(1:2);
V_RL_whl = V_RL(1:2);
V_RR_whl = V_RR(1:2);

xhat =  x;
P_out = P;

end</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="12" name="Q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
