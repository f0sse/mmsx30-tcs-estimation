__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_734.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="734">
  <P Name="name">TruckMaker/Subsystem1/ONE_TRACK_MODEL_TRACTOR_UKF/UKF_ONE_TRACK4</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">734</P>
  <P Name="ssIdHighWaterMark">65</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">54</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_TruckTrailer</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">734</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P, dxdt, innovation, K_out, S_out, z_pred_out,truck_Ff,truck_Fr, trailer_v_hitch,trailer_v_axle,trailer_F_hitch,trailer_F_tire,truck_v_hitch] = UKF_TruckTrailer(z,u,Q,R,Ts,data)
persistent x Pk dxdt_old t
%% =========================
%% INIT
%% =========================
if isempty(x)
    x = [15;0.1;0.1;7.5;7.5;0;0;4]; % [vx vy wz Cf Cr psi wz_tr Cr_tr]
end
if isempty(Pk)
    Pk = diag([0.1 0.1 0.1 5 5 0.03 0.1 5]);
end
if isempty(dxdt_old)
    dxdt_old = zeros(8,1);
end
if isempty(t)
    t = 0;
end
t = data;
if t &lt; 30
    xhat=x; P=Pk; dxdt=dxdt_old;
    
    innovation=zeros(length(z),1);
    K_out=zeros(length(x), length(z));
    S_out=eye(length(z));
    z_pred_out=zeros(length(z),1);
    
    trailer_v_axle   = zeros(3,1);
    trailer_v_hitch = zeros(3,1);
    truck_Ff = zeros(2,1);
    truck_Fr = zeros(2,1);
    truck_v_hitch=zeros(3,1);
    
    %% Normal Forces 
    trailer_F_hitch = zeros(2,1);
    trailer_F_tire = zeros(2,1);
    
    return
end
%% =========================
%% CONSTANTS
%% =========================
g = 9.82;
% Truck
m = 6800; 
Jz = 12994.917; 
Rwheel = 0.50;
w_track = 2.1; 
% Trailer
m_tr = 31960;
Jz_tr = 145971.764;
% Geometry &amp; koordinat punkter på Truck
p_cog = [3.473;0;0.925];
p_fax = [4.520;0;0.50];
p_rax = [0.950;0;0.50];
p_imu = [3.600;0;1.000];
hitch = [1.9;0;1.21];
Rcog = p_imu - p_cog;
hHitch= hitch(3);
lf = abs(p_fax(1)-p_cog(1)); 
lr = abs(p_cog(1)-p_rax(1)); 
L = lf + lr;
h = p_cog(3);
Rfax = p_fax - p_cog; Rfax(3)=-p_cog(3);
Rrax = p_rax - p_cog; Rrax(3)=-p_cog(3);
Rhitch = hitch - p_cog;
lhitch = Rhitch(1);
%lfhitch = abs(p_fax(1) -hitch(1));

% Geometry Trailer
p_cog_tr = [-6.195;0;1.95];
p_rFax_tr = [-7.75;0;0.5];
p_rMax_tr = [-9.0;0;0.5];
p_rRax_tr = [-10.25;0;0.5];
hitch_tr = [-1.25;0;1.25];

% Avstånd från hitch till trailer-punkter
lf_tr = abs(hitch_tr(1)-p_cog_tr(1));
lr_f_tr = abs(p_cog_tr(1)-p_rFax_tr(1));
lr_m_tr = abs(p_cog_tr(1)-p_rMax_tr(1));
lr_r_tr = abs(p_cog_tr(1)-p_rRax_tr(1));
L_tr = lf_tr + lr_r_tr;

% Vektorer från trailer-CoG till axlar (för cross-product)
Frax_tr = p_rFax_tr - hitch_tr; Frax_tr(3)=-hitch_tr(3);
Mrax_tr = p_rMax_tr - hitch_tr; Mrax_tr(3)=-hitch_tr(3);
Rlrax_tr = p_rRax_tr - hitch_tr; Rlrax_tr(3)=-hitch_tr(3);
h_tr = p_cog_tr(3);
%% =========================
%% INPUTS
%% =========================
delta = u(1); 
T_rl = u(2);   
T_rr = u(3);
Fxh = u(4); 
%Fyh = u(5)*0; 
Fx_f_brake  = -abs(u(6)) / Rwheel; 
Fx_r_brake  = -abs(u(7)) / Rwheel;
%Fx_tr_brake = -abs(u(8)) / Rwheel;
Fx_vehicle = (T_rl+T_rr)/Rwheel + Fx_r_brake +Fx_f_brake;
%% =========================
%% UKF PARAMS
%% =========================
n = length(x);
nSPx = 2*n+1;
W0 = 1 - n/3;
Wi = (1 - W0)/(2*n);
gamma = sqrt(n/(1 - W0));
%% =========================
%% SIGMA POINTS (PRIOR)
%% =========================
Pk = (Pk+Pk&apos;)/2 + 1e-9*eye(n);
Sx = chol(Pk,&apos;lower&apos;);
X_pre = zeros(n,nSPx);
X_pre(:,1) = x;
for i=1:n
    X_pre(:,i+1)   = x + gamma*Sx(:,i);
    X_pre(:,i+1+n) = x - gamma*Sx(:,i);
end
%% =========================
%% PREDICTION
%% =========================
X_pred = zeros(n,nSPx);
dxdt_model = zeros(n,1);
truck_Ff = zeros(2,1);
truck_Fr = zeros(2,1);
truck_v_hitch=zeros(3,1);
%%Trailer data
trailer_v_axle   = zeros(3,1);
trailer_v_hitch = zeros(3,1);
trailer_F_hitch = zeros(2,1);
trailer_F_tire = zeros(2,1);
for k=1:nSPx
    Xk = X_pre(:,k);
    vx=Xk(1); vy=Xk(2); wz=Xk(3);Cf=Xk(4); Cr=Xk(5);
    
    psi=Xk(6); wz_tr=Xk(7); Cr_tr=Xk(8);
    
    v_cog=[vx;vy;0];
    omega=[0;0;wz];
    
    %% ===== TRAILER =====
    v_hitch_truck = v_cog + cross(omega,Rhitch);
    
    Rot_tr=[cos(psi)  sin(psi) 0;
            -sin(psi) cos(psi)  0;
            0           0      1];
    omega_tr=[0;0;wz_tr];
    
    ax_tr = Fxh/m_tr;

    v_hitch_trailer = Rot_tr * v_hitch_truck;
    
    v_tr_f = v_hitch_trailer + cross(omega_tr, Frax_tr);
    v_tr_m = v_hitch_trailer + cross(omega_tr,Mrax_tr);
    v_tr_r = v_hitch_trailer + cross(omega_tr, Rlrax_tr);

    
    alpha_tr_f = atan2(v_tr_f(2), max(abs(v_tr_f(1)), 0.1));
    alpha_tr_m = atan2(v_tr_m(2),max(abs(v_tr_m(1)),0.1));
    alpha_tr_r = atan2(v_tr_r(2), max(abs(v_tr_r(1)), 0.1));
    
    
   
    
    Fz_hitch = (m_tr*g*lr_r_tr/L_tr - m_tr*ax_tr*(h_tr-hHitch)/L_tr);
    Fz_tr    = (m_tr*g - Fz_hitch)/3;

    Fy_f_tr = -Cr_tr * alpha_tr_f * Fz_tr;
    Fy_m_tr = -Cr_tr* alpha_tr_m * Fz_tr;
    Fy_r_tr = -Cr_tr * alpha_tr_r * Fz_tr;
    
    %+ lm_tr*Fym_tr
    % Beräknar modellens sidkraft för hitch
    Fyh_mod = (lr_m_tr * Fy_m_tr  + lr_f_tr * Fy_f_tr + lr_r_tr * Fy_r_tr) / lf_tr;
 
    if k==1
        trailer_v_hitch = v_hitch_trailer;
        trailer_v_axle=v_tr_m;
        
        truck_v_hitch=v_hitch_truck;
        trailer_F_hitch = [Fyh_mod;Fz_hitch];
        trailer_F_tire = [Fy_m_tr;Fz_tr];
    end
    %% ===== TRUCK =====
    Rotf=[cos(delta) -sin(delta) 0;
          sin(delta) cos(delta)  0; 
              0            0     1];
    vf = Rotf.&apos;*(v_cog + cross(omega,Rfax));
    vr = v_cog + cross(omega,Rrax);
    
    alpha_f = atan2(vf(2),max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2),max(abs(vr(1)),0.1));
    
    F_hitch_trailer=[u(4); Fyh_mod; 0];
    F_hitch_body= Rot_tr.&apos; * F_hitch_trailer;
    ax_est = (Fx_vehicle - F_hitch_body(1))/m; 
    
    %Ffz = (m*g*lr - m*ax_est*(h-hHitch) + Fz_hitch*(hitch(1) - p_rax(1)) ) / L; %- F_hitch_body(1)*hHitch
    %Frz = (m*g*lf + m*ax_est*(h-hHitch) + Fz_hitch*(p_fax(1) - hitch(1)) ) / L; %+ F_hitch_body(1)*hHitch
    
    Ffz = (m*g*lr - m*ax_est*h + Fz_hitch*(hitch(1) - p_rax(1)) - F_hitch_body(1)*hHitch) / L;
    Frz = (m*g*lf + m*ax_est*h + Fz_hitch*(p_fax(1) - hitch(1)) + F_hitch_body(1)*hHitch) / L;
    Fy_f = -Cf*alpha_f*Ffz;
    Fy_r = -Cr*alpha_r*Frz;
    
    %% ===== DYNAMICS =====
    dvx = (Fx_vehicle - Fy_f*sin(delta) - F_hitch_body(1))/m + vy*wz;
    dvy = (Fy_f*cos(delta) + Fy_r - F_hitch_body(2))/m - vx*wz;
    dwz = (lf*Fy_f*cos(delta) - lr*Fy_r - lhitch*(F_hitch_body(2)))/Jz;
    dpsi = wz - wz_tr; 
    
    ay_hitch_truck = (Fy_f*cos(delta) + Fy_r - F_hitch_body(2))/m; % Truckens acceleration
    Fyh_mod = m_tr * (ay_hitch_truck) - (Fy_f_tr + Fy_m_tr + Fy_r_tr);
    % --- ÄNDRING HÄR FÖR ATT FIXA OFFSET ---
   
    %dwz_tr = (-lr_r_tr*Fy_m_tr + lf_tr*Fyh_mod )/Jz_tr;
    %dwz_tr = (lf_tr*Fyh_mod - lr_f_tr*Fy_f_tr - lr_m_tr*Fy_m_tr - lr_r_tr*Fy_r_tr)/Jz_tr;
    %dwz_tr = (lf_tr * Fyh_mod - (lr_f_tr * Fy_f_tr + lr_m_tr * Fy_m_tr + lr_r_tr * Fy_r_tr)) / Jz_tr;
    dwz_tr = (lf_tr*Fyh_mod - lr_f_tr*Fy_f_tr - lr_m_tr*Fy_m_tr - lr_r_tr*Fy_r_tr)/Jz_tr;
    % ---------------------------------------
    
    if k==1
        dxdt_model=[dvx;dvy;dwz;0;0;dpsi;dwz_tr;0];
        truck_Ff = [Fy_f;Ffz];
        truck_Fr =  [Fy_r;Frz];
    end
    X_pred(:,k) = Xk + Ts*[dvx; dvy; dwz; 0; 0; dpsi; dwz_tr; 0];
end
%% ===== MEAN &amp; COV
x_pred=zeros(n,1);
P_pred=zeros(n);
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    x_pred=x_pred+w*X_pred(:,k);
end
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    dx=X_pred(:,k)-x_pred;
    P_pred=P_pred+w*(dx*dx&apos;);
end
P_pred=P_pred+Q*Ts;
%% =========================
%% MEASUREMENT
%% =========================
Sx=chol((P_pred+P_pred&apos;)/2 + 1e-9*eye(n),&apos;lower&apos;);
X_post=zeros(n,nSPx);
X_post(:,1)=x_pred;
for i=1:n
    X_post(:,i+1)  =x_pred + gamma*Sx(:,i);
    X_post(:,i+1+n)=x_pred - gamma*Sx(:,i);
end
Z=zeros(10,nSPx); % Fixat till 10 rader
for k=1:nSPx
    Xk=X_post(:,k);
    vx=Xk(1); vy=Xk(2); wz=Xk(3); Cf=Xk(4); Cr=Xk(5);
    psi=Xk(6); wz_tr=Xk(7); Cr_tr=Xk(8); 
    
    v_cog=[vx;vy;0]; omega=[0;0;wz];
    Rot_tr=[cos(psi) sin(psi) 0;
            -sin(psi)  cos(psi) 0;  
                0         0    1];
    omega_tr=[0;0;wz_tr];
    % v_hitch_tr = Rot_tr.&apos; * (v_cog + cross(omega,Rhitch));
    % v_tr_m = v_hitch_tr + cross(omega_tr,Mrax_tr);
    % alpha_tr_m = atan2(v_tr_m(2),max(abs(v_tr_m(1)),0.1));
    % ax_tr = Fxh / m_tr; 
    % 
    % Fz_hitch = (m_tr*g*lr_r_tr/L_tr - m_tr*ax_tr*(h_tr-hHitch)/L_tr);
    % Fy_m_tr = -Cr_tr*alpha_tr_m*(m_tr*g - Fz_hitch);
    % Fyh_mod = (lr_m_tr * Fy_m_tr) / lf_tr; 

    ax_tr = Fxh/m_tr;

    v_hitch_trailer = Rot_tr * v_hitch_truck;
    
    v_tr_f = v_hitch_trailer + cross(omega_tr, Frax_tr);
    v_tr_m = v_hitch_trailer + cross(omega_tr,Mrax_tr);
    v_tr_r = v_hitch_trailer + cross(omega_tr, Rlrax_tr);

    alpha_tr_f = atan2(v_tr_f(2), max(abs(v_tr_f(1)), 0.1));
    alpha_tr_m = atan2(v_tr_m(2),max(abs(v_tr_m(1)),0.1));
    alpha_tr_r = atan2(v_tr_r(2), max(abs(v_tr_r(1)), 0.1));
    
    Fz_hitch = (m_tr*g*lr_r_tr/L_tr - m_tr*ax_tr*(h_tr-hHitch)/L_tr);
    Fz_tr    = (m_tr*g - Fz_hitch)/3;

    Fy_f_tr = -Cr_tr * alpha_tr_f * Fz_tr;
    Fy_m_tr = -Cr_tr* alpha_tr_m * Fz_tr;
    Fy_r_tr = -Cr_tr * alpha_tr_r * Fz_tr;
    
    %+ lm_tr*Fym_tr
    % Beräknar modellens sidkraft för hitch
    Fyh_mod = (lr_m_tr * Fy_m_tr  + lr_f_tr * Fy_f_tr + lr_r_tr * Fy_r_tr) / lf_tr;
    
    
    Rotf=[cos(delta) -sin(delta) 0; 
          sin(delta)  cos(delta) 0; 
              0           0      1];
    vf = Rotf.&apos;*(v_cog + cross(omega,Rfax));
    alpha_f = atan2(vf(2),max(abs(vf(1)),0.1));
    alpha_r = atan2(vy - lr*wz, max(abs(vx),0.1));
    
    F_hitch_body= Rot_tr.&apos;* [u(4); Fyh_mod; 0];
    ax_est = (Fx_vehicle - F_hitch_body(1))/m;
    %Ffz = (m*g*lr - m*ax_est*(h-hHitch) + Fz_hitch*(hitch(1) - p_rax(1)) ) / L; %- F_hitch_body(1)*hHitch
    %Frz = (m*g*lf + m*ax_est*(h-hHitch) + Fz_hitch*(p_fax(1) - hitch(1)) ) / L; %+ F_hitch_body(1)*hHitch
    Ffz = (m*g*lr - m*ax_est*h + Fz_hitch*(hitch(1) - p_rax(1)) - F_hitch_body(1)*hHitch) / L;
    Frz = (m*g*lf + m*ax_est*h + Fz_hitch*(p_fax(1) - hitch(1)) + F_hitch_body(1)*hHitch) / L;
    
    Fy_f = -Cf*alpha_f*Ffz;
    Fy_r = -Cr*alpha_r*Frz;
    
    a_spec_x = (Fx_vehicle - Fy_f*sin(delta) - F_hitch_body(1))/m;
    
    a_spec_y = (Fy_f*cos(delta) + Fy_r - F_hitch_body(2))/m;
    
    dwz = (lf*Fy_f*cos(delta) - lr*Fy_r - lhitch*(F_hitch_body(2)))/Jz;
    
    a_imu = [a_spec_x; a_spec_y; 0] + cross(omega,cross(omega,Rcog)) + cross([0;0;dwz],Rcog);
    v_imu = v_cog + cross(omega,Rcog);
    
    omega_rl = (vx - wz * w_track/2) / Rwheel;
    omega_rr = (vx + wz * w_track/2) / Rwheel;
    omega_tr_ML = (v_tr_m(1) - wz_tr * w_track/2) / Rwheel;
    omega_tr_MR = (v_tr_m(1) + wz_tr * w_track/2) / Rwheel;
    
    % Z: [ax; ay; vx; vy; wz; w_rl; w_rr; w_tr_l; w_tr_r; Fyh]
    Z(:,k)=[a_imu(1:2); v_imu(1); v_imu(2); wz; omega_rl; omega_rr; omega_tr_ML; omega_tr_MR; Fyh_mod];
end
%% ===== REST
z_pred=zeros(10,1);
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    z_pred=z_pred+w*Z(:,k);
end
valid_idx=true(10,1);
valid_idx=valid_idx &amp; ~isnan(z);
z_used=z(valid_idx);
z_pred_used=z_pred(valid_idx);
Z_used=Z(valid_idx,:);
R_used=R(valid_idx,valid_idx);
S_cov=zeros(length(z_used));
Pxz=zeros(n,length(z_used));
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    dz=Z_used(:,k)-z_pred_used;
    dx=X_post(:,k)-x_pred;
    S_cov=S_cov+w*(dz*dz&apos;);
    Pxz=Pxz+w*(dx*dz&apos;);
end
S_cov=S_cov+R_used;
K=Pxz/S_cov;
x=x_pred + K*(z_used - z_pred_used);
Pk=P_pred - K*S_cov*K&apos;;
Pk=(Pk+Pk&apos;)/2 + 1e-9*eye(n);
%% OUTPUT
xhat=x;
P=Pk;
dxdt=dxdt_model;
innovation=zeros(length(z),1);
innovation(valid_idx)=z_used - z_pred_used;
K_out=zeros(n,length(z));
K_out(:,valid_idx)=K;
S_out=zeros(length(z));
S_out(valid_idx,valid_idx)=S_cov;
z_pred_out=z_pred;
end</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
