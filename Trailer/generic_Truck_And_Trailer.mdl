__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_191.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="191">
  <P Name="name">TruckMaker/Two_TRack_Model/Two Track Model1</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">191</P>
  <P Name="ssIdHighWaterMark">26</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">10</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_4Wheel</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">191</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat,P_out,Fy_mean,alpha_mean,...
          V_FL_whl,V_FR_whl,V_RL_whl,V_RR_whl] ...
          = UKF_4Wheel(z,u,Q,R,Ts)

persistent x P

%% ================= INIT =================
if isempty(x)
    x = [15; 0; 0.01; 10; 10; 10; 10];  % startvärden på cornering stiffness
end

if isempty(P)
    P = diag([1 1 0.01 1 1 1 1]);
end

n = length(x);
m = length(z);

%% ================= VEHICLE =================
m_car = 7000;
Jz = 14232.357;
lf = 4.52;
lr = 0.95;
R_w = 0.49;
track=2.10;
h_CoM = 1;  % höjd på CoM

%% ================= INPUTS =================
delta_FL = u(1);
delta_FR = u(2);
delta_RL = 0;
delta_RR = 0;

Fx_FL = u(5)/R_w;
Fx_FR = u(6)/R_w;
Fx_RL = u(7)/R_w;
Fx_RR = u(8)/R_w;

%% ================= ROTATION MATRICES =================
R_FL = [cos(delta_FL) sin(delta_FL);
       -sin(delta_FL) cos(delta_FL)];

R_FR = [cos(delta_FR) sin(delta_FR);
       -sin(delta_FR) cos(delta_FR)];

R_RL = eye(2);
R_RR = eye(2);

%% ================= GEOMETRY =================
tire_FL = [lf;  track/2; 0];
tire_FR = [lf; -track/2; 0];
tire_RL = [lr;  track/2; 0];
tire_RR = [lr; -track/2; 0];

CoM = [3.6; 0; h_CoM];  

rFL = tire_FL - CoM;
rFR = tire_FR - CoM;
rRL = tire_RL - CoM;
rRR = tire_RR - CoM;

%% ================= UKF =================
W0 = 1 - n/3;
Wi = (1 - W0)/(2*n);
gamma = sqrt(n/(1-W0));

S = chol(P,&apos;lower&apos;);

X = zeros(n,2*n+1);
X(:,1) = x;

for i=1:n
    X(:,i+1)   = x + gamma*S(:,i);
    X(:,i+1+n) = x - gamma*S(:,i);
end

%% ================= PROPAGATION =================
X_pred = zeros(n,2*n+1);
Fy_sigma = zeros(4,2*n+1);
alpha_sigma = zeros(4,2*n+1);

for k=1:2*n+1

    vx = X(1,k);
    vy = X(2,k);
    r  = X(3,k);

    Cf_FL = X(4,k);
    Cf_FR = X(5,k);
    Cr_RL = X(6,k);
    Cr_RR = X(7,k);

    Vc = [vx; vy; 0];
    omega = [0;0;r];

    V_FL = Vc + cross(omega,rFL);
    V_FR = Vc + cross(omega,rFR);
    V_RL = Vc + cross(omega,rRL);
    V_RR = Vc + cross(omega,rRR);

    V_FL_l = R_FL*V_FL(1:2);
    V_FR_l = R_FR*V_FR(1:2);
    V_RL_l = V_RL(1:2);
    V_RR_l = V_RR(1:2);
    
    % Side slip angles
    alpha_FL = atan2(V_FL_l(2),max(abs(V_FL_l(1)),0.1));
    alpha_FR = atan2(V_FR_l(2),max(abs(V_FR_l(1)),0.1));
    alpha_RL = atan2(V_RL_l(2),max(abs(V_RL_l(1)),0.1));
    alpha_RR = atan2(V_RR_l(2),max(abs(V_RR_l(1)),0.1));

    % ================= LOAD TRANSFER =================
    Fz_FL = m_car/4*9.81 - m_car*r*vy - m_car*vx^2*lr/(lf+lr); % enkel approx
    Fz_FR = m_car/4*9.81 - m_car*r*vy - m_car*vx^2*lr/(lf+lr);
    Fz_RL = m_car/4*9.81 + m_car*r*vy + m_car*vx^2*lf/(lf+lr);
    Fz_RR = m_car/4*9.81 + m_car*r*vy + m_car*vx^2*lf/(lf+lr);

    % ================= FORCES =================
    Fy_FL = -Cf_FL * Fz_FL * alpha_FL;
    Fy_FR = -Cf_FR * Fz_FR * alpha_FR;
    Fy_RL = -Cr_RL * Fz_RL * alpha_RL;
    Fy_RR = -Cr_RR * Fz_RR * alpha_RR;

    F_FL = R_FL&apos;*[Fx_FL;Fy_FL];
    F_FR = R_FR&apos;*[Fx_FR;Fy_FR];
    F_RL = [Fx_RL;Fy_RL];
    F_RR = [Fx_RR;Fy_RR];

    Fx_sum = F_FL(1)+F_FR(1)+F_RL(1)+F_RR(1);
    Fy_sum = F_FL(2)+F_FR(2)+F_RL(2)+F_RR(2);

    dvx = Fx_sum/m_car + vy*r;
    dvy = Fy_sum/m_car - vx*r;

    Mz = (lf-CoM(1))*(F_FL(2)+F_FR(2)) - (CoM(1)-lr)*(F_RL(2)+F_RR(2)) ...
        + (track/2)*(F_FR(1)-F_FL(1)) + (track/2)*(F_RR(1)-F_RL(1));
    dr = Mz / Jz;

    X_pred(:,k) = [vx+dvx*Ts;
                   vy+dvy*Ts;
                   r+dr*Ts;
                   Cf_FL;
                   Cf_FR;
                   Cr_RL;
                   Cr_RR];

    Fy_sigma(:,k)    = [F_FL(2);F_FR(2);F_RL(2);F_RR(2)];
    alpha_sigma(:,k) = [alpha_FL;alpha_FR;alpha_RL;alpha_RR];
end

%% ================= UKF MEAN &amp; COVARIANCE =================
W = [W0 repmat(Wi,1,2*n)];
Fy_mean = Fy_sigma*W&apos;;
alpha_mean = alpha_sigma*W&apos;;

% State mean
x_pred = W0*X_pred(:,1);
for k=2:2*n+1
    x_pred = x_pred + Wi*X_pred(:,k);
end

% State covariance
P_pred = Q*Ts;
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    P_pred = P_pred + w*(dx*dx&apos;);
end

%% ================= MEASUREMENT =================
Z_sigma = zeros(m,2*n+1);

for k=1:2*n+1
    vx = X_pred(1,k);
    vy = X_pred(2,k);
    r  = X_pred(3,k);

    Cf_FL = X_pred(4,k);
    Cf_FR = X_pred(5,k);
    Cr_RL = X_pred(6,k);
    Cr_RR = X_pred(7,k);

    Vc = [vx;vy;0];
    omega = [0;0;r];

    V_FL = Vc + cross(omega,rFL);
    V_FR = Vc + cross(omega,rFR);
    V_RL = Vc + cross(omega,rRL);
    V_RR = Vc + cross(omega,rRR);

    V_FL_l = R_FL*V_FL(1:2);
    V_FR_l = R_FR*V_FR(1:2);
    V_RL_l = V_RL(1:2);
    V_RR_l = V_RR(1:2);

    alpha_FL = atan2(V_FL_l(2),max(abs(V_FL_l(1)),0.1));
    alpha_FR = atan2(V_FR_l(2),max(abs(V_FR_l(1)),0.1));
    alpha_RL = atan2(V_RL_l(2),max(abs(V_RL_l(1)),0.1));
    alpha_RR = atan2(V_RR_l(2),max(abs(V_RR_l(1)),0.1));

     % ================= LOAD TRANSFER =================
    Fz_FL = m_car/4*9.81 - m_car*r*vy - m_car*vx^2*lr/(lf+lr); % enkel approx
    Fz_FR = m_car/4*9.81 - m_car*r*vy - m_car*vx^2*lr/(lf+lr);
    Fz_RL = m_car/4*9.81 + m_car*r*vy + m_car*vx^2*lf/(lf+lr);
    Fz_RR = m_car/4*9.81 + m_car*r*vy + m_car*vx^2*lf/(lf+lr);

    Fy_FL = -Cf_FL * Fz_FL * alpha_FL;
    Fy_FR = -Cf_FR * Fz_FR * alpha_FR;
    Fy_RL = -Cr_RL * Fz_RL * alpha_RL;
    Fy_RR = -Cr_RR * Fz_RR * alpha_RR;

    F_FL = R_FL&apos;*[Fx_FL;Fy_FL];
    F_FR = R_FR&apos;*[Fx_FR;Fy_FR];
    F_RL = [Fx_RL;Fy_RL];
    F_RR = [Fx_RR;Fy_RR];

    Fx_sum = F_FL(1)+F_FR(1)+F_RL(1)+F_RR(1);
    Fy_sum = F_FL(2)+F_FR(2)+F_RL(2)+F_RR(2);

    w_FL = V_FL_l(1)/R_w;
    w_FR = V_FR_l(1)/R_w;
    w_RL = V_RL_l(1)/R_w;
    w_RR = V_RR_l(1)/R_w;

    ax = Fx_sum/m_car;
    ay = Fy_sum/m_car;

    Z_sigma(:,k) = [ax; ay; vx; vy; r; w_FL; w_FR; w_RL; w_RR];
end

%% ================= UKF UPDATE =================
% Measurement mean
z_pred = W0*Z_sigma(:,1);
for k=2:2*n+1
    z_pred = z_pred + Wi*Z_sigma(:,k);
end

% Measurement covariance
S_cov = R;
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dz = Z_sigma(:,k) - z_pred;
    S_cov = S_cov + w*(dz*dz&apos;);
end

% Cross covariance
Pxz = zeros(n,length(z));
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    dz = Z_sigma(:,k) - z_pred;
    Pxz = Pxz + w*(dx*dz&apos;);
end

% Kalman update
K = Pxz / S_cov;
x = x_pred + K*(z - z_pred);
P = P_pred - K*S_cov*K&apos;;

%% ================= OUTPUT =================
vx = x(1); vy = x(2); r = x(3);

Vc = [vx;vy;0];
omega = [0;0;r];

V_FL = Vc + cross(omega,rFL);
V_FR = Vc + cross(omega,rFR);
V_RL = Vc + cross(omega,rRL);
V_RR = Vc + cross(omega,rRR);

V_FL_whl = R_FL*V_FL(1:2);
V_FR_whl = R_FR*V_FR(1:2);
V_RL_whl = V_RL(1:2);
V_RR_whl = V_RR(1:2);

xhat =  x;
P_out = P;
Fy_mean = Fy_mean;
alpha_mean = alpha_mean;

end</P>
      </eml>
    </state>
