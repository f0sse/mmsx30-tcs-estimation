<?xml version="1.0" encoding="utf-8"?>
<chart id="118">
  <P Name="name">TruckMaker/Two_TRack_Model/MATLAB Function2</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">118</P>
  <P Name="ssIdHighWaterMark">17</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">5</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">AdaptiveOneTrackCFCR</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">118</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [vx, vy, wz, Cf_est, Cr_est, Fyf, Fyr] = AdaptiveOneTrackCFCR(z, u, Ts)
% Adaptive one-track model for online estimation of front/rear cornering stiffness
%
% Inputs:
%   z  = [ax; ay; vx; vy; wz] -&gt; sensor measurements
%   u  = [delta; Fx]          -&gt; steering angle (rad), longitudinal force (N)
%   Ts -&gt; sampling time (s)
%
% Outputs:
%   vx, vy, wz      -&gt; vehicle states (m/s, m/s, rad/s)
%   Cf_est, Cr_est  -&gt; estimated front/rear cornering stiffness (N/rad)
%   Fyf, Fyr        -&gt; lateral forces (N)

persistent Cf Cr vx_prev vy_prev wz_prev

%% ---------------- Initialization ----------------
if isempty(vx_prev)
    vx_prev = z(3); vy_prev = z(4); wz_prev = z(5);
end
if isempty(Cf)
    Cf = 15000;  % initial guess
    Cr = 15000;
end

%% ---------------- Vehicle parameters ----------------
m  = 7000;      % mass [kg]
Jz = 14232.357; % yaw inertia [kg*m^2]
lf = 1.12;      % front CoG to axle [m]
lr = 2.45;      % rear CoG to axle [m]
Rw = 0.49;      % wheel radius [m]
track = 2.49;   % track width [m]

%% ---------------- Inputs ----------------
delta = u(1); % steering [rad]
Fx    = u(2); % longitudinal force [N]

%% ---------------- States from sensors ----------------
vx = z(3); 
vy = z(4); 
wz = z(5);

% Protect low velocity
vx_eff = max(abs(vx), 1);

%% ---------------- Slip angles ----------------
alpha_f = (vy + lf*wz)/vx_eff - delta;
alpha_r = (vy - lr*wz)/vx_eff;

%% ---------------- Lateral forces ----------------
Fyf = -Cf * alpha_f;
Fyr = -Cr * alpha_r;

%% ---------------- Approximate derivatives ----------------
% simple backward difference
dv_y = (vy - vy_prev)/Ts;
dw_z = (wz - wz_prev)/Ts;

%% ---------------- Regression for Cf/Cr ----------------
% Linear regression: y = Phi * [Cf; Cr]
y   = [m*(dv_y + vx*wz); Jz*dw_z];
Phi = [alpha_f, alpha_r; lf*alpha_f, -lr*alpha_r];

% Adaptive gain
gamma = 1e3;

theta = [Cf; Cr] + gamma * Phi&apos; * (y - Phi*[Cf; Cr]) * Ts;

% Limit to physical range
Cf = theta(1);%max(min(theta(1), 1e5), 5000);
Cr = theta(2);%max(min(theta(2), 1e5), 5000);

Cf_est = Cf;
Cr_est = Cr;

%% ---------------- Recompute lateral forces ----------------
Fyf = Cf_est * alpha_f;
Fyr = -Cr_est * alpha_r;

%% ---------------- Update previous states ----------------
vx_prev = vx;
vy_prev = vy;
wz_prev = wz;

end
</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
