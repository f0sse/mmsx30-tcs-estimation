      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function vel_meas = imu_vel_noise(truth)
    

sigma = 0.05; % m/s^2 (tune later)

vel_meas = truth + sigma * randn(size(truth));


