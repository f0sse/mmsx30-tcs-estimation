<?xml version="1.0" encoding="utf-8"?>
<chart id="69">
  <P Name="name">TruckMaker/Two_TRack_Model/MATLAB Function1</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">69</P>
  <P Name="ssIdHighWaterMark">12</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">1</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">CKF_Bicycle_IPG</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">69</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P] = CKF_Bicycle_IPG(z, u, Q, R, Ts)
% Cubature Kalman Filter for One-Track vehicle model
% States: [vx vy r Cf Cr]&apos;
% Measurements: [ay r vx]&apos;

% -------------------------------------------------
% Persistent states (SIMULINK SAFE)
% -------------------------------------------------
persistent x Pk

if isempty(x)
    x  = [15; 0; 0.05; 6e4; 6e4];
    Pk = diag([1 1 0.05 2e4 2e4].^2);
end

n = length(x);   % state dimension
m = length(z);   % measurement dimension

% -------------------------------------------------
% Cubature points
% -------------------------------------------------
Xi = sqrt(n) * [eye(n) -eye(n)];
W  = ones(1,2*n) / (2*n);

% -------------------------------------------------
% PREDICTION STEP
% -------------------------------------------------
X_pred = zeros(n,2*n);
S = chol(Pk,&apos;lower&apos;);

for i = 1:2*n
    X_sigma = x + S*Xi(:,i);
    X_pred(:,i) = VehicleDynamics(X_sigma, u, Ts);
end

x_pred = X_pred * W&apos;;

P_pred = Q;
for i = 1:2*n
    dx = X_pred(:,i) - x_pred;
    P_pred = P_pred + W(i) * (dx*dx&apos;);
end

% -------------------------------------------------
% MEASUREMENT PREDICTION
% -------------------------------------------------
Z_sigma = zeros(m,2*n);
for i = 1:2*n
    Z_sigma(:,i) = MeasurementModel(X_pred(:,i), u);
end

z_pred = Z_sigma * W&apos;;

Pzz = R;
Pxz = zeros(n,m);
for i = 1:2*n
    dz = Z_sigma(:,i) - z_pred;
    dx = X_pred(:,i) - x_pred;
    Pzz = Pzz + W(i)*(dz*dz&apos;);
    Pxz = Pxz + W(i)*(dx*dz&apos;);
end

% -------------------------------------------------
% UPDATE STEP
% -------------------------------------------------
K = Pxz / Pzz;

x  = x_pred + K*(z - z_pred);
Pk = P_pred - K*Pzz*K&apos;;

xhat = x;
P    = Pk;

end
function x_next = VehicleDynamics(x, u, Ts)

% States
vx = x(1); vy = x(2); r = x(3);
Cf = x(4); Cr = x(5);

% Inputs
delta = u(1);    % steering angle [rad]
Fx    = u(2);    % longitudinal force [N]

% Vehicle parameters
m  = 7000;
Jz = 14232;
lf = 1.12;
lr = 2.45;

vx_eff = max(abs(vx), 3);

% Slip angles
alpha_f = (vy + lf*r)/vx_eff - delta;
alpha_r = (vy - lr*r)/vx_eff;

% Tire forces
Fyf = -Cf * alpha_f;
Fyr = -Cr * alpha_r;

% Dynamics
dvx = (Fx - Fyf*sin(delta) + vy*r)/m;
dvy = (Fyf*cos(delta) + Fyr - vx*r)/m;
dr  = (lf*Fyf*cos(delta) - lr*Fyr)/Jz;

% Parameters as random walk
dCf = 0;
dCr = 0;

% Euler integration
x_next = x + Ts*[dvx; dvy; dr; dCf; dCr];

end
function z = MeasurementModel(x, u)

vx = x(1); vy = x(2); r = x(3);
Cf = x(4); Cr = x(5);
delta = u(1);

% Vehicle parameters
m  = 7000;
lf = 1.12;
lr = 2.45;

vx_eff = max(abs(vx),3);

% Slip angles
alpha_f = (vy + lf*r)/vx_eff - delta;
alpha_r = (vy - lr*r)/vx_eff;

% Tire forces
Fyf = -Cf * alpha_f;
Fyr = -Cr * alpha_r;

% Lateral acceleration (IMU)
dvy = (Fyf*cos(delta) + Fyr - vx*r)/m;
ay  = dvy + vx*r;

% Measurement vector
z = [
    ay
    r
    vx
];

end
</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
