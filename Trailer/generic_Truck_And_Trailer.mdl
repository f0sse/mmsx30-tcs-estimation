<?xml version="1.0" encoding="utf-8"?>
<chart id="81">
  <P Name="name">TruckMaker/Two_TRack_Model/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">81</P>
  <P Name="ssIdHighWaterMark">13</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">2</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">EKF_Bicycle_Full_NoBias</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">81</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P] = EKF_Bicycle_Full_NoBias(z, u, Q, R, Ts)
% EKF for One-Track / Bicycle Model (No IMU Bias)
% States: x = [vx; vy; r; Cf; Cr]
% Measurements: z = [ax; ay; vx; vy; r; wL; wR]

persistent x Pk
if isempty(x)
    % Initial state guess
    x = [15; 0; 0.05; 6e4; 6e4]; % vx, vy, r, Cf, Cr
    Pk = diag([1 1 0.05 2e4 2e4].^2);
end

%% Vehicle parameters
m  = 7000;       % mass
Jz = 14232;      % yaw inertia
lf = 1.12;       % front CG distance
lr = 2.45;       % rear CG distance
Rw = 0.49;       % wheel radius
track = 2.49;    % track width

%% Inputs
delta = u(1); % steering angle
Fx = u(2);    % longitudinal force

%% States
vx = x(1); vy = x(2); r = x(3);
Cf = x(4); Cr = x(5);

%% Protect low velocity
vx_eff = max(abs(vx), 3);

%% ---------------- Prediction ----------------
% Slip angles
alpha_f = (vy + lf*r)/vx_eff - delta;
alpha_r = (vy - lr*r)/vx_eff;

% Tire lateral forces
Fyf = -Cf*alpha_f; % Cyf= FyF/slip
Fyr = -Cr*alpha_r;

% Vehicle dynamics
dvx = (Fx - Fyf*sin(delta) + vy*r)/m;
dvy = (Fyf*cos(delta) + Fyr - vx*r)/m;
dr  = (lf*Fyf*cos(delta) - lr*Fyr)/Jz;

% State propagation
xdot = [dvx; dvy; dr; 0; 0];
x_pred = x + Ts*xdot;

%% ---------------- Jacobian F ----------------
F = eye(5);

% Partial derivatives for F
% alpha derivatives
dalf_dvx = -(vy + lf*r)/vx_eff^2;
dalf_dvy = 1/vx_eff;
dalf_dr  = lf/vx_eff;

dalr_dvx = -(vy - lr*r)/vx_eff^2;
dalr_dvy = 1/vx_eff;
dalr_dr  = -lr/vx_eff;

dFyf = -Cf*[dalf_dvx; dalf_dvy; dalf_dr];
dFyr = -Cr*[dalr_dvx; dalr_dvy; dalr_dr];

% dvx
F(1,1) = 1 + Ts*(-sin(delta)*dFyf(1))/m;
F(1,2) = Ts*(r - sin(delta)*dFyf(2))/m;
F(1,3) = Ts*(vy - sin(delta)*dFyf(3))/m;
F(1,4) = Ts*(-alpha_f*sin(delta))/m;

% dvy
F(2,1) = Ts*(-r + cos(delta)*dFyf(1) + dFyr(1))/m;
F(2,2) = 1 + Ts*(cos(delta)*dFyf(2) + dFyr(2))/m;
F(2,3) = Ts*( -vx + cos(delta)*dFyf(3) + dFyr(3))/m;
F(2,4) = Ts*(-alpha_f*cos(delta))/m;
F(2,5) = Ts*(-alpha_r)/m;

% dr
F(3,1) = Ts*(lf*cos(delta)*dFyf(1) - lr*dFyr(1))/Jz;
F(3,2) = Ts*(lf*cos(delta)*dFyf(2) - lr*dFyr(2))/Jz;
F(3,3) = 1 + Ts*(lf*cos(delta)*dFyf(3) - lr*dFyr(3))/Jz;
F(3,4) = Ts*(-lf*alpha_f*cos(delta))/Jz;
F(3,5) = Ts*(lr*alpha_r)/Jz;

%% ---------------- Covariance prediction ----------------
P_pred = F*Pk*F&apos; + Q;

%% ---------------- Measurement model ----------------
ax_hat = dvx - vy*r;                % longitudinal accel
ay_hat = dvy + vx*r;                % lateral accel
vx_hat = vx;
vy_hat = vy;
r_hat  = r;
wL_hat = (vx - track/2 * r)/Rw;
wR_hat = (vx + track/2 * r)/Rw;

z_hat = [ax_hat; ay_hat; vx_hat; vy_hat; r_hat; wL_hat; wR_hat];

%% ---------------- Measurement Jacobian H ----------------
H = zeros(7,5);

% ax = dvx - vy*r
H(1,1) = 0; % optional: include dvx derivative
H(1,2) = -r;
H(1,3) = -vy;

% ay = dvy + vx*r
H(2,1) = r;
H(2,2) = 1;
H(2,3) = vx;
H(2,4) = -alpha_f*cos(delta)/m;
H(2,5) = -alpha_r/m;

% vx
H(3,1) = 1;

% vy
H(4,2) = 1;

% r
H(5,3) = 1;

% wheel speeds
H(6,1) = 1/Rw;
H(6,3) = -track/(2*Rw);

H(7,1) = 1/Rw;
H(7,3) = track/(2*Rw);

%% ---------------- EKF update ----------------
S = H*P_pred*H&apos; + R;
K = P_pred*H&apos;/S;

x = x_pred + K*(z - z_hat);
Pk = (eye(5) - K*H)*P_pred;

%% ---------------- Output ----------------
xhat = x;
P = Pk;

end
</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="xhat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="Q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="R">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="Ts">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="P">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
