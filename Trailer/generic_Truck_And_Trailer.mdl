<?xml version="1.0" encoding="utf-8"?>
<chart id="209">
  <P Name="name">TruckMaker/Subsystem1/ONE_TRACK_MODEL_TRACTOR_UKF/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">209</P>
  <P Name="ssIdHighWaterMark">67</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">11</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">stiffness_computation</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">209</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Cf, Cr, alpha_f, alpha_r] = stiffness_computation(z, u)
%
% Signal: z = [ ax; ay; az; 
%               vx; vy; vz;
%               rx; ry; rz;
%               alphax; alphay; alphaz;
%               wFL; wFR; wRL; wRR; ]
%
%         u = [ delta; T_rl; T_rr; ]
%

% ------------------------------------------------------------------------%
% Physics
% ------------------------------------------------------------------------%

g = 9.82; % [m/s^2]

% ------------------------------------------------------------------------%
% Truck Parameters
% ------------------------------------------------------------------------%

% Mass [kg]
m = 6800;

% Inertial tensor [kg m^2]
J = [
     5430.025, 0.000,    -589.488;
     0.000,    9407.562,  0.000;
    -589.488,  0.000,     12994.917;
];

% Position vectors [m]
p_cog  = [3.473, 0.000, 0.925].&apos;;  % Center of Gravity
p_fax  = [4.520, 0.000, 0.490].&apos;;  % Front axle
p_rax  = [0.950, 0.000, 0.490].&apos;;  % Rear axle
p_bod  = [3.600, 0.000, 1.000].&apos;;  % Body frame
p_imu  = p_bod;

% p_wfl  = [4.520,  1.050, 0.490].&apos;; % Front wheel left
% p_wfr  = [4.520, -1.050, 0.490].&apos;; % Front wheel right
% 
% p_wrl  = [0.950,  1.050, 0.490].&apos;; % Rear wheel left
% p_wrcl = [0.950,  0.860, 0.490].&apos;; % Rear wheel carrier left
% p_wrcr = [0.950, -0.860, 0.490].&apos;; % Rear wheel carrier right
% p_wrr  = [0.950, -1.050, 0.490].&apos;; % Rear wheel right
% 
% Axle load
% m_f = 4805.882; % [kg]
% m_r = 2194.118; % [kg]
% 
% Wheel base
% long = [1,0,0] * abs(p_fax - p_rax); % length [m]
% wide = [0,1,0] * abs(p_wrr - p_wrl); % width  [m]

% CoG hight
high = p_cog(3);

% Wheel radius
% Rwf = 0.505;
% Rwr = 0.505;

% longitudinal distance from cog to axles
lf = [1,0,0] * abs(p_fax - p_cog);
lr = [1,0,0] * abs(p_rax - p_cog);

% ------------------------------------------------------------------------%
% Inputs
% ------------------------------------------------------------------------%

a =  [z(1:2);0]; % IMU acceleration
v =  [z(3:4);0]; % IMU velocity

alpha = [0;0;0];     % IMU yaw acceleration

omega = [0;0;z(end)];  % IMU yaw rate


delta = u(1); % steering angle of one-track front wheel (pre-computed)

T_rl = u(2); % rear left  torque (not used)
T_rr = u(3); % rear right torque (not used)
 
% ------------------------------------------------------------------------%
% Translate measurements
% ------------------------------------------------------------------------%

% displacement vectors
Rfax = p_fax - p_imu; Rfax(3) = -p_imu(3); % straight projection to contact
Rrax = p_rax - p_imu; Rrax(3) = -p_imu(3); % --||--
Rcog = p_cog - p_imu;

% rotation matrix
Rotf = [ 
   cos(delta), -sin(delta), 0;
   sin(delta),  cos(delta), 0;
            0,           0, 1;
];

% velocity translation
% --------------------
vf = Rotf.&apos; * (v + cross(omega, Rfax));
vr = eye(3) * (v + cross(omega, Rrax));

% acceleration translation 
% ------------------------
acog = a + cross(omega, cross(omega, Rcog)) + cross(alpha, Rcog);

% ------------------------------------------------------------------------%
% Computation
% ------------------------------------------------------------------------%

% lateral forces
% --------------
%Ffy = (J(3,3)*alpha(3)+m*acog(2)*lr) / (long * cos(delta));
%Fry = (m*acog(2)*lf - J(3,3)*alpha(3)) / long;

Ffy = (acog(2)*lr) / cos(delta);
Fry = (acog(2)*lf);

% slip
% ----
alpha_f = atan2(vf(2), max(abs(vf(1)), .1));
alpha_r = atan2(vr(2), max(abs(vr(1)), .1));

% normal forces
% -------------
%Ffz = m*g*lr/long - m*acog(1)*high/long;
%Frz = m*g*lf/long + m*acog(1)*high/long;

Ffz = g*lr - acog(1)*high;
Frz = g*lf + acog(1)*high;

% normalized coefficients
% -----------------------
Cf = Ffy / (alpha_f * Ffz); % reference 
Cr = Fry / (alpha_r * Frz); % reference 
 </P>
      </eml>
    </state>
    <data SSID="49" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="Cf">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="13" name="Cr">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="14" name="alpha_f">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="15" name="alpha_r">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">209</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">209</P>
      <P Name="type">CONNECTIVE_JUNCTION</P>
