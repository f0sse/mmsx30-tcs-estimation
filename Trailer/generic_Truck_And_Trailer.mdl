  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">14</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_TruckTrailer_Robust</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">257</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat,P] = UKF_TruckTrailer_Robust(z,u,Q,R,Ts)

persistent x Pk

%% INITIALIZATION

if isempty(x)

    % [vx vy r theta Cf Cr Ct]

    x = [15;0.1;0.01;0;5;5;5];

end

if isempty(Pk)

    Pk = diag([1 1 0.1 0.01 5 5 5]);

end


%% PARAMETERS (fill from TruckMaker later)

m  = PARAM.m;
Jz = PARAM.Jz;

mt = PARAM.mt;

lf = PARAM.lf;
lr = PARAM.lr;

lh = PARAM.lh;     % hitch distance
lt = PARAM.lt;     % trailer axle distance

g = 9.82;


%% INPUTS

delta = u(1);
Fx    = u(2);

ay_meas = z(2);


%% EXCITATION CHECK

excitation = abs(ay_meas) &gt; 0.3 &amp;&amp; abs(delta) &gt; 0.5*pi/180;


%% UKF PARAMETERS

n = length(x);

W0 = 1 - n/3;
Wi = (1-W0)/(2*n);
gamma = sqrt(n/(1-W0));

Pk = (Pk+Pk&apos;)/2 + 1e-9*eye(n);

S = chol(Pk,&apos;lower&apos;);


%% SIGMA POINTS

X = zeros(n,2*n+1);
X(:,1) = x;

for i=1:n

    X(:,i+1)   = x + gamma*S(:,i);
    X(:,i+1+n) = x - gamma*S(:,i);

end


%% PROPAGATION

X_pred = zeros(n,2*n+1);

for k=1:2*n+1

vx = X(1,k);
vy = X(2,k);
r  = X(3,k);
theta = X(4,k);

Cf = X(5,k);
Cr = X(6,k);
Ct = X(7,k);


%% SLIP ANGLES

alpha_f = delta - atan2(vy + lf*r , max(vx,0.5));

alpha_r = -atan2(vy - lr*r , max(vx,0.5));

alpha_t = -atan2(vy - (lr+lt)*r + lh*r , max(vx,0.5));


%% NORMAL FORCES

Ffz = PARAM.Ffz;
Frz = PARAM.Frz;

Ftz = PARAM.Ftz;


%% LATERAL FORCES

Fy_f = Cf * alpha_f * Ffz;

Fy_r = Cr * alpha_r * Frz;

Fy_t = Ct * alpha_t * Ftz;


%% VEHICLE DYNAMICS

dvx = Fx/m + vy*r;

dvy = (Fy_f*cos(delta) + Fy_r + Fy_t)/(m+mt) - vx*r;

dr  = (-lf*Fy_f*cos(delta) + lr*Fy_r - lh*Fy_t)/Jz;


%% ARTICULATION

dtheta = r - (vy - (lr+lt)*r)/lh;


%% PROPAGATION

X_pred(:,k) = [

vx + Ts*dvx
vy + Ts*dvy
r  + Ts*dr
theta + Ts*dtheta
Cf
Cr
Ct

];

end


%% MEAN

x_pred = W0*X_pred(:,1);

for k=2:2*n+1

x_pred = x_pred + Wi*X_pred(:,k);

end


%% COVARIANCE

P_pred = Q;

for k=1:2*n+1

w = (k==1)*W0 + (k&gt;1)*Wi;

dx = X_pred(:,k)-x_pred;

P_pred = P_pred + w*(dx*dx&apos;);

end


%% MEASUREMENT MODEL

Z = zeros(length(z),2*n+1);

for k=1:2*n+1

vx = X_pred(1,k);
vy = X_pred(2,k);
r  = X_pred(3,k);

ax = Fx/m + vy*r;

ay = -vx*r;

Z(:,k) = [

ax
ay
vx
vy
r

];

end


%% MEASUREMENT MEAN

z_pred = W0*Z(:,1);

for k=2:2*n+1

z_pred = z_pred + Wi*Z(:,k);

end


%% MEASUREMENT COV

S_cov = R;

for k=1:2*n+1

w = (k==1)*W0 + (k&gt;1)*Wi;

dz = Z(:,k)-z_pred;

S_cov = S_cov + w*(dz*dz&apos;);

end


%% CROSS COV

Pxz = zeros(n,length(z));

for k=1:2*n+1

w = (k==1)*W0 + (k&gt;1)*Wi;

dx = X_pred(:,k)-x_pred;

dz = Z(:,k)-z_pred;

Pxz = Pxz + w*(dx*dz&apos;);

end


%% UPDATE

K = Pxz / S_cov;

x = x_pred + K*(z - z_pred);

Pk = P_pred - K*S_cov*K&apos;;


%% ROBUST CONSTRAINTS

x(5) = min(max(x(5),0.01),20);   % Cf

x(6) = min(max(x(6),0.01),20);   % Cr

x(7) = min(max(x(7),0.01),20);   % Ct


%% EXCITATION FREEZE

if ~excitation

x(5:7) = x_pred(5:7);

end


%% ARTICULATION LIMIT

if abs(x(4)) &gt; 20*pi/180

x(7) = x_pred(7);

end


xhat = x;

P = Pk;

end</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="xhat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="Q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="R">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="Ts">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
