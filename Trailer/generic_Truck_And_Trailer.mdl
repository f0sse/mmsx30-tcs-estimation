<?xml version="1.0" encoding="utf-8"?>
<chart id="220">
  <P Name="name">TruckMaker/Subsystem1/ONE_TRACK_MODEL_TRACTOR_UKF/UKF_ONE_TRACK_TruckAndTrailer</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">220</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">65</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">12</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_TruckTrailer</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">220</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P, dxdt, innovation, K_out, S_out, z_pred_out,truck_Ff,truck_Fr, trailer_v_hitch,trailer_v_axle,trailer_F_hitch,trailer_F_tire,truck_v_hitch] = UKF_TruckTrailer(z,u,Q,R,Ts,data)

persistent x Pk dxdt_old t
%% =========================
%% INIT
%% =========================
if isempty(x)
    x = [15;0.1;0.1;14;14;0;0;5]; % [vx vy wz Cf Cr psi wz_tr Cr_tr]
end
if isempty(Pk)
    Pk = diag([0.1 0.1 0.1 5 5 0.03 0.1 5]);
end
if isempty(dxdt_old)
    dxdt_old = zeros(8,1);
end
if isempty(t)
    t = 0;
end
t = data;
if t &lt; 30
    xhat=x; P=Pk; dxdt=dxdt_old;
    
    innovation=zeros(length(z),1);
    K_out=zeros(length(x), length(z));
    S_out=eye(length(z));
    z_pred_out=zeros(length(z),1);
    
    trailer_v_axle   = zeros(3,1);
    trailer_v_hitch = zeros(3,1);
    truck_Ff = zeros(2,1);
    truck_Fr = zeros(2,1);
    truck_v_hitch=zeros(3,1);
    
    trailer_F_hitch = zeros(2,1);
    trailer_F_tire = zeros(2,1);
    
    return
end

%% =========================
%% CONSTANTS
%% =========================
g = 9.82;
% Truck
m = 6800; 
Jz = 12994.917; 
Rwheel = 0.50;
w_track = 2.1; 
% Trailer
m_tr = 31960;
Jz_tr = 145971.764;
% Geometry &amp; koordinat punkter på Truck
p_cog = [3.473;0;0.925];
p_fax = [4.520;0;0.49];
p_rax = [0.950;0;0.49];
p_imu = [3.600;0;1.000];
hitch = [1.9;0;1.21];
Rcog = p_imu - p_cog;
hHitch= hitch(3);
lf = abs(p_fax(1)-p_cog(1)); 
lr = abs(p_cog(1)-p_rax(1)); 
L = lf + lr;
h = p_cog(3);
Rfax = p_fax - p_cog; Rfax(3)=-p_cog(3);
Rrax = p_rax - p_cog; Rrax(3)=-p_cog(3);
Rhitch = hitch - p_cog;
lhitch = Rhitch(1);
% Geometry Trailer
p_cog_tr = [-6.195;0;1.95];
p_rFax_tr = [-7.75;0;0.49];
p_rMax_tr = [-9.0;0;0.49];
p_rRax_tr = [-10.25;0;0.49];
hitch_tr = [-1.25;0;1.25];

% Avstånd från hitch till trailer-punkter
lf_h_tr = abs(hitch_tr(1)-p_cog_tr(1));
lr_f_tr = abs(p_cog_tr(1)-p_rFax_tr(1));
lr_m_tr = abs(p_cog_tr(1)-p_rMax_tr(1));
lr_r_tr = abs(p_cog_tr(1)-p_rRax_tr(1));
L_tr = lf_h_tr + lr_m_tr; % Hävarm till mittaxel

% Vektorer från trailer-CoG till axlar (för cross-product)
Frax_tr = p_rFax_tr - p_cog_tr; Frax_tr(3) = -p_cog_tr(3);
Mrax_tr = p_rMax_tr - p_cog_tr; Mrax_tr(3) = -p_cog_tr(3);
Rlrax_tr = p_rRax_tr - p_cog_tr; Rlrax_tr(3) =-p_cog_tr(3);
Rhitch_tr = hitch_tr - p_cog_tr; Rhitch_tr(3) = -abs(hitch_tr(3)-p_cog_tr(3));

h_cog_tr = p_cog_tr(3);

% Statisk load transfer parametrar (beräknas en gång)
l_1 = -lr_f_tr; l_2 = -lr_m_tr; l_3 = -lr_r_tr;
l_h = lf_h_tr;
mg_tr = m_tr * g;
denom = l_1 + l_2 + l_3 - 3*l_h;

%% =========================
%% INPUTS
%% =========================
delta = u(1); 
T_rl  = u(2);   
T_rr  = u(3);
Fxh   = u(4); 
Fx_f_brake  = -abs(u(6)) / Rwheel; 
Fx_r_brake  = -abs(u(7)) / Rwheel;
Fx_vehicle  = (T_rl+T_rr)/Rwheel + Fx_r_brake +Fx_f_brake;

%% =========================
%% UKF PARAMS
%% =========================
n = length(x);
nSPx = 2*n+1;
W0 = 1 - n/3;
Wi = (1 - W0)/(2*n);
gamma = sqrt(n/(1 - W0));

%% =========================
%% SIGMA POINTS (PRIOR)
%% =========================
Pk = (Pk+Pk&apos;)/2 + 1e-9*eye(n);
Sx = chol(Pk,&apos;lower&apos;);
X_pre = zeros(n,nSPx);
X_pre(:,1) = x;
for i=1:n
    X_pre(:,i+1)   = x + gamma*Sx(:,i);
    X_pre(:,i+1+n) = x - gamma*Sx(:,i);
end

%% =========================
%% PREDICTION
%% =========================
X_pred = zeros(n,nSPx);
dxdt_model = zeros(n,1);
truck_Ff = zeros(2,1);
truck_Fr = zeros(2,1);
truck_v_hitch = zeros(3,1);
    
trailer_v_axle = zeros(3,1);
trailer_v_hitch = zeros(3,1);
trailer_F_hitch = zeros(2,1);
trailer_F_tire = zeros(2,1);

for k=1:nSPx
    Xk = X_pre(:,k);
    vx=Xk(1); vy=Xk(2); wz=Xk(3); Cf=Xk(4); Cr=Xk(5);
    psi=Xk(6); wz_tr=Xk(7); Cr_tr=Xk(8);
    
    v_cog=[vx;vy;0];
    omega=[0;0;wz];
    
    %% ===== TRAILER =====
    v_hitch_truck = v_cog + cross(omega,Rhitch);
    
    Rot_tr=[cos(psi) -sin(psi) 0;
            sin(psi) cos(psi)  0; 
              0         0      1];
   
    v_hitch_trailer = Rot_tr&apos; * v_hitch_truck;
    
    % *** STATISK LOAD TRANSFER (Axels metod) ***
    Fz_hitch = (mg_tr * (l_1 + l_2 + l_3)) / denom;
    Fz_tr_each = -(l_h * mg_tr) / denom;
    
    % Begränsa till fysiska värden
    Fz_hitch = max(100, min(Fz_hitch, m_tr*g));
    Fz_tr_each = max(100, min(Fz_tr_each, m_tr*g));

    % Hastigheter och slip för traileraxlar (relativt trailer CoG)
    omega_tr = [0;0;wz_tr];
    v_cog_tr = v_hitch_trailer - cross(omega_tr, Rhitch_tr);
    
    v_tr_f = v_cog_tr + cross(omega_tr, Frax_tr);
    v_tr_m = v_cog_tr + cross(omega_tr, Mrax_tr);
    v_tr_r = v_cog_tr + cross(omega_tr, Rlrax_tr);  
    
    alpha_tr_f = atan2(v_tr_f(2), max(abs(v_tr_f(1)), 0.1));
    alpha_tr_m = atan2(v_tr_m(2), max(abs(v_tr_m(1)), 0.1));
    alpha_tr_r = atan2(v_tr_r(2), max(abs(v_tr_r(1)), 0.1));
    
    Fy_f_tr = -Cr_tr * alpha_tr_f * Fz_tr_each;
    Fy_m_tr = -Cr_tr * alpha_tr_m * Fz_tr_each;
    Fy_r_tr = -Cr_tr * alpha_tr_r * Fz_tr_each;
    
    % Hitch-kraft (momentjämvikt)
    Fyh_mod = (Fy_f_tr*lr_f_tr + Fy_m_tr*lr_m_tr + Fy_r_tr*lr_r_tr) / (L_tr);
     
    if k==1
        trailer_v_hitch = v_hitch_trailer;
        trailer_v_axle = v_tr_m;
        truck_v_hitch = v_hitch_truck;
        trailer_F_hitch = [Fyh_mod; Fz_hitch];
        trailer_F_tire = [Fy_m_tr; Fz_tr_each];
    end

    %% ===== TRUCK =====
    % Transformera hitch-krafter till Truckens system
    F_hitch_body = Rot_tr * [Fxh; Fyh_mod; 0];
    
    Rotf=[cos(delta) -sin(delta)  0; 
          sin(delta)  cos(delta)  0;
              0           0       1];
    vf = Rotf&apos;*(v_cog + cross(omega,Rfax));
    vr = v_cog + cross(omega,Rrax);
    
    alpha_f = atan2(vf(2),max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2),max(abs(vr(1)),0.1));
    
    % Vertikallast Truck
    ax_est = (Fx_vehicle - F_hitch_body(1))/m; 
    Ffz = (m*g*lr - m*ax_est*h + Fz_hitch*(hitch(1) - p_rax(1)) - F_hitch_body(1)*hHitch) / L;
    Frz = (m*g*lf + m*ax_est*h + Fz_hitch*(p_fax(1) - hitch(1)) + F_hitch_body(1)*hHitch) / L;
    
    Fy_f = -Cf * alpha_f * Ffz;
    Fy_r = -Cr * alpha_r * Frz;
    
    %% ===== DYNAMICS =====
    dvx = (Fx_vehicle - Fy_f*sin(delta) - F_hitch_body(1))/m + vy*wz;
    dvy = (Fy_f*cos(delta) + Fy_r - F_hitch_body(2))/m - vx*wz;
    dwz = (lf*Fy_f*cos(delta) - lr*Fy_r - lhitch*F_hitch_body(2))/Jz;
    
    dpsi = wz_tr - wz;  % Rätt tecken!
    
    % Moment kring trailer Cog
    dwz_tr = (lf_h_tr*Fyh_mod - lr_f_tr*Fy_f_tr - lr_m_tr*Fy_m_tr - lr_r_tr*Fy_r_tr)/Jz_tr;
    
    if k==1
        dxdt_model=[dvx;dvy;dwz;0;0;dpsi;dwz_tr;0];
        truck_Ff = [Fy_f;Ffz];
        truck_Fr = [Fy_r;Frz];
    end
    X_pred(:,k) = Xk + Ts*[dvx; dvy; dwz; 0; 0; dpsi; dwz_tr; 0];
end

%% ===== MEAN &amp; COV
x_pred=zeros(n,1);
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    x_pred=x_pred+w*X_pred(:,k);
end
P_pred=zeros(n);
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    dx=X_pred(:,k)-x_pred;
    P_pred=P_pred+w*(dx*dx&apos;);
end
P_pred=P_pred+Q*Ts;

%% =========================
%% MEASUREMENT UPDATE
%% =========================
Sx=chol((P_pred+P_pred&apos;)/2 + 1e-9*eye(n),&apos;lower&apos;);
X_post=zeros(n,nSPx);
X_post(:,1)=x_pred;
for i=1:n
    X_post(:,i+1)  =x_pred + gamma*Sx(:,i);
    X_post(:,i+1+n)=x_pred - gamma*Sx(:,i);
end

Z=zeros(10,nSPx);
for k=1:nSPx
    Xk=X_post(:,k);
    vx=Xk(1); vy=Xk(2); wz=Xk(3); Cf=Xk(4); Cr=Xk(5);
    psi=Xk(6); wz_tr=Xk(7); Cr_tr=Xk(8); 

    v_cog=[vx;vy;0];
    omega=[0;0;wz];
    
    % *** SAMMA STATISKA LOAD TRANSFER som i prediction ***
    Fz_hitch_meas = (mg_tr * (l_1 + l_2 + l_3)) / denom;
    Fz_tr_each_meas = -(l_h * mg_tr) / denom;
    
    Fz_hitch_meas = max(100, min(Fz_hitch_meas, m_tr*g));
    Fz_tr_each_meas = max(100, min(Fz_tr_each_meas, m_tr*g));
    
    % Upprepa kraftberäkning för z_pred
    Rot_tr=[cos(psi) -sin(psi) 0;
            sin(psi)  cos(psi) 0;
                0       0      1];

    v_hitch_tr = Rot_tr&apos; * ([vx;vy;0] + cross([0;0;wz],Rhitch));
    
    % Samma logik som i prediction
    v_cog_tr_meas = v_hitch_tr - cross([0;0;wz_tr], Rhitch_tr);
    v_tr_m_meas = v_cog_tr_meas + cross([0;0;wz_tr], Mrax_tr);
    alpha_tr_m = atan2(v_tr_m_meas(2), max(abs(v_tr_m_meas(1)), 0.1));
    Fy_m_tr_meas = -Cr_tr * alpha_tr_m * Fz_tr_each_meas;
   
    % Beräkna Fy_f_tr och Fy_r_tr för hitch-kraften
    v_tr_f_meas = v_cog_tr_meas + cross([0;0;wz_tr], Frax_tr);
    v_tr_r_meas = v_cog_tr_meas + cross([0;0;wz_tr], Rlrax_tr);
    alpha_tr_f_meas = atan2(v_tr_f_meas(2), max(abs(v_tr_f_meas(1)), 0.1));
    alpha_tr_r_meas = atan2(v_tr_r_meas(2), max(abs(v_tr_r_meas(1)), 0.1));
    Fy_f_tr_meas = -Cr_tr * alpha_tr_f_meas * Fz_tr_each_meas;
    Fy_r_tr_meas = -Cr_tr * alpha_tr_r_meas * Fz_tr_each_meas;
    
    % Hitch-kraft (momentjämvikt)
    Fyh_mod_meas = (Fy_f_tr_meas*lr_f_tr + Fy_m_tr_meas*lr_m_tr + Fy_r_tr_meas*lr_r_tr) / L_tr;

    
    F_hitch_body = Rot_tr * [Fxh; Fyh_mod_meas; 0];
    
    % Vertikallast Truck för measurement
    ax_est_meas = (Fx_vehicle - F_hitch_body(1))/m; 
    Ffz_meas = (m*g*lr - m*ax_est_meas*h + Fz_hitch_meas*(hitch(1) - p_rax(1)) - F_hitch_body(1)*hHitch) / L;
    Frz_meas = (m*g*lf + m*ax_est_meas*h + Fz_hitch_meas*(p_fax(1) - hitch(1)) + F_hitch_body(1)*hHitch) / L;

    Rotf=[cos(delta) -sin(delta)  0; 
          sin(delta)  cos(delta)  0;
              0           0       1];
    vf = Rotf&apos;*(v_cog + cross(omega,Rfax));
    vr = v_cog + cross(omega,Rrax);
    
    alpha_f = atan2(vf(2),max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2),max(abs(vr(1)),0.1));
    
    %alpha_f = atan2(vy + lf*wz, max(abs(vx),0.1)) - delta;
    %alpha_r = atan2(vy - lr*wz, max(abs(vx),0.1));
    Fy_f_meas = -Cf * alpha_f * Ffz_meas;
    Fy_r_meas = -Cr * alpha_r * Frz_meas;
    
    a_spec_x = (Fx_vehicle - Fy_f_meas*sin(delta) - F_hitch_body(1))/m;
    a_spec_y = (Fy_f_meas*cos(delta) + Fy_r_meas - F_hitch_body(2))/m;
    dwz_m = (lf*Fy_f_meas*cos(delta) - lr*Fy_r_meas - lhitch*F_hitch_body(2))/Jz;
    
    a_imu = [a_spec_x; a_spec_y; 0] + cross([0;0;wz],cross([0;0;wz],Rcog)) + cross([0;0;dwz_m],Rcog);
    v_imu = [vx;vy;0] + cross([0;0;wz],Rcog);
    
    Z(:,k)=[a_imu(1:2); v_imu(1); v_imu(2); wz; ...
            (vx - wz*w_track/2)/Rwheel; (vx + wz*w_track/2)/Rwheel; ...
            (v_tr_m_meas(1) - wz_tr*w_track/2)/Rwheel; (v_tr_m_meas(1) + wz_tr*w_track/2)/Rwheel; Fyh_mod_meas];
end

z_pred=zeros(10,1);
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    z_pred=z_pred+w*Z(:,k);
end

valid_idx = ~isnan(z);
z_used = z(valid_idx);
z_pred_used = z_pred(valid_idx);
R_used = R(valid_idx,valid_idx);

S_cov=zeros(length(z_used));
Pxz=zeros(n,length(z_used));
for k=1:nSPx
    w=(k==1)*W0+(k&gt;1)*Wi;
    dz=Z(valid_idx,k)-z_pred_used;
    dx=X_post(:,k)-x_pred;
    S_cov=S_cov+w*(dz*dz&apos;);
    Pxz=Pxz+w*(dx*dz&apos;);
end
S_cov=S_cov+R_used;
K=Pxz/S_cov;

x=x_pred + K*(z_used - z_pred_used);
Pk=P_pred - K*S_cov*K&apos;;
Pk=(Pk+Pk&apos;)/2 + 1e-9*eye(n);

%% OUTPUT
xhat=x; P=Pk; dxdt=dxdt_model;
innovation=zeros(length(z),1); innovation(valid_idx)=z_used - z_pred_used;
K_out=zeros(n,length(z)); K_out(:,valid_idx)=K;
S_out=zeros(length(z)); S_out(valid_idx,valid_idx)=S_cov;
z_pred_out=z_pred;

end</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="xhat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="Q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="30" name="R">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="Ts">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="P">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="31" name="dxdt">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="32" name="innovation">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="33" name="K_out">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
