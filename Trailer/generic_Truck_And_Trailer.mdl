<?xml version="1.0" encoding="utf-8"?>
<chart id="488">
  <P Name="name">TruckMaker/Tractor_Subsystem /ONE_TRACK_MODEL_TRACTOR_UKF/MATLAB Function2</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">488</P>
  <P Name="ssIdHighWaterMark">16</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">34</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_OneTrack_IMU</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">488</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P, dxdt, innovation, K_out, S_out, z_pred_out] = UKF_OneTrack_IMU(z, u, Q, R, Ts, data)
z=z(1:5);
persistent x Pk dxdt_old t

%% =========================
%% INIT
%% =========================
if isempty(x)
    % [vx vy wz Cf Cr bax]
    x = [15;0.1;0.1;7.5;7.5;0];
end

if isempty(Pk)
    Pk = diag([0.1 0.1 0.1 5 5 0.5]);
end

if isempty(dxdt_old)
    dxdt_old = zeros(6,1);
end

if isempty(t)
    t = 0;
end

t = data;

if t &lt; 30
    xhat = x;
    P = Pk;
    dxdt = dxdt_old;
    innovation = zeros(length(z),1);
    K_out = zeros(length(x), length(z));
    S_out = eye(length(z));
    z_pred_out = zeros(length(z),1);
    return
end

IDX_VX = 3;
IDX_VY = 4;

%% =========================
%% VEHICLE CONSTANTS
%% =========================
g  = 9.82;

p_cog = [3.473;0;0.925];
p_fax = [4.520;0;0.490];
p_rax = [0.950;0;0.490];
p_imu = [3.600;0;1.000];

lf = abs(p_fax(1)-p_cog(1));
lr = abs(p_cog(1)-p_rax(1));
L  = lf + lr;
h  = p_cog(3);

Rfax = p_fax - p_cog; Rfax(3) = -p_cog(3);
Rrax = p_rax - p_cog; Rrax(3) = -p_cog(3);
Rcog = p_imu - p_cog;

%% =========================
%% INPUTS
%% =========================
delta = u(1);
T_rl  = u(2);
T_rr  = u(3);
Rwheel = 0.505;
Fx_vehicle = (T_rl + T_rr)/Rwheel;

%% =========================
%% UKF PARAMS
%% =========================
n = length(x);
nSPx = 2*n + 1;

W0 = 1 - n/3;
Wi = (1 - W0)/(2*n);
gamma = sqrt(n/(1-W0));

%% =========================
%% SIGMA POINTS (PRIOR)
%% =========================
Pk = (Pk + Pk&apos;)/2 + 1e-9*eye(n);
Sx = chol(Pk,&apos;lower&apos;);

X_pre = zeros(n,nSPx);
X_pre(:,1) = x;

for i=1:n
    X_pre(:,i+1)   = x + gamma*Sx(:,i);
    X_pre(:,i+1+n) = x - gamma*Sx(:,i);
end

%% =========================
%% PREDICTION
%% =========================
X_pred = zeros(n,nSPx);
dxdt_model = zeros(n,1);

m = 6800; 
Jz = 12994.917;

for k=1:nSPx

    Xk = X_pre(:,k);

    vx = Xk(1); vy = Xk(2); wz = Xk(3);
    Cf = Xk(4); Cr = Xk(5);
    bax = Xk(6);

    v_cog = [vx; vy; 0]; 
    omega = [0; 0; wz];

    Rotf = [cos(delta) -sin(delta) 0;
            sin(delta)  cos(delta) 0;
            0 0 1];

    vf = Rotf.&apos;*(v_cog + cross(omega,Rfax));
    vr = v_cog + cross(omega,Rrax);

    alpha_f = atan2(vf(2), max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2), max(abs(vr(1)),0.1));

    ax_est = Fx_vehicle/m + vy*wz;

    Ffz = m*g*lr/L - m*ax_est*h/L;
    Frz = m*g*lf/L + m*ax_est*h/L;

    Fy_f = -Cf*alpha_f*Ffz;
    Fy_r = -Cr*alpha_r*Frz;

    dvx = (Fx_vehicle - Fy_f*sin(delta))/m + vy*wz + bax;

    % Testa DÄMPNING här (NYCKELN!)
    dvy = (Fy_f*cos(delta)+Fy_r)/m - vx*wz;

    dwz = (lf*Fy_f*cos(delta) - lr*Fy_r)/Jz;

    if k==1
        dxdt_model = [dvx; dvy; dwz; 0; 0; 0];
    end

    X_pred(:,k) = [
        vx + Ts*dvx
        vy + Ts*dvy
        wz + Ts*dwz
        Cf
        Cr
        bax
    ];
end

%% =========================
%% MEAN
%% =========================
x_pred = zeros(n,1);
for k=1:nSPx
    w = (k==1)*W0 + (k&gt;1)*Wi;
    x_pred = x_pred + w*X_pred(:,k);
end

%% =========================
%% COVARIANCE
%% =========================
P_pred = zeros(n);
for k=1:nSPx
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    P_pred = P_pred + w*(dx*dx&apos;);
end

P_pred = P_pred + Q*Ts;
P_pred = (P_pred + P_pred&apos;)/2 + 1e-9*eye(n);

%% =========================
%% SIGMA POINTS (POST)
%% =========================
Sx = chol(P_pred,&apos;lower&apos;);

X_post = zeros(n,nSPx);
X_post(:,1) = x_pred;

for i=1:n
    X_post(:,i+1)   = x_pred + gamma*Sx(:,i);
    X_post(:,i+1+n) = x_pred - gamma*Sx(:,i);
end

%% =========================
%% MEASUREMENT MODEL
%% =========================
Z = zeros(length(z), nSPx);

for k=1:nSPx

    Xk = X_post(:,k);

    vx = Xk(1); vy = Xk(2); wz = Xk(3);
    Cf = Xk(4); Cr = Xk(5);
    bax = Xk(6);

    v_cog = [vx; vy; 0]; 
    omega=[0;0;wz];

    Rotf=[cos(delta) -sin(delta) 0;
          sin(delta)  cos(delta) 0;
          0 0 1];

    vf = Rotf.&apos;*(v_cog+cross(omega,Rfax));
    vr = v_cog+cross(omega,Rrax);

    alpha_f = atan2(vf(2), max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2), max(abs(vr(1)),0.1));

    ax_est = Fx_vehicle/m + vy*wz;

    Ffz = m*g*lr/L - m*ax_est*h/L;
    Frz = m*g*lf/L + m*ax_est*h/L;

    Fy_f = -Cf*alpha_f*Ffz;
    Fy_r = -Cr*alpha_r*Frz;
    
    dvx = (Fx_vehicle - Fy_f*sin(delta))/m;
    dvy = (Fy_f*cos(delta)+Fy_r)/m;
    dwz = (lf*Fy_f*cos(delta) - lr*Fy_r)/Jz;

    a_cog = [dvx; dvy; 0];
    alpha_vec=[0;0;dwz];

    a_imu = a_cog + cross(omega,cross(omega,Rcog)) + cross(alpha_vec,Rcog);
    v_imu = v_cog + cross(omega,Rcog);

    ax_meas = a_imu(1) + bax;

    Z(:,k) = [
        ax_meas
        a_imu(2)
        v_imu(1:2)
        wz
    ];
end

%% =========================
%% MEASUREMENT MEAN
%% =========================
z_pred = zeros(length(z),1);
for k=1:nSPx
    w = (k==1)*W0 + (k&gt;1)*Wi;
    z_pred = z_pred + w*Z(:,k);
end

%% =========================
%% SENSOR SELECTION
%% =========================
valid_idx = true(length(z),1);

if isnan(z(IDX_VX))
    valid_idx(IDX_VX) = false;
    valid_idx(IDX_VY) = false;
end

valid_idx = valid_idx &amp; ~isnan(z);

z_used = z(valid_idx);
z_pred_used = z_pred(valid_idx);
Z_used = Z(valid_idx,:);
R_used = R(valid_idx,valid_idx);

%% =========================
%% S + Pxz
%% =========================
S_cov = zeros(length(z_used));
Pxz = zeros(n,length(z_used));

for k=1:nSPx
    w = (k==1)*W0 + (k&gt;1)*Wi;

    dz = Z_used(:,k)-z_pred_used;
    dx = X_post(:,k)-x_pred;

    S_cov = S_cov + w*(dz*dz&apos;);
    Pxz = Pxz + w*(dx*dz&apos;);
end

S_cov = S_cov + R_used;
S_cov = (S_cov + S_cov&apos;)/2 + 1e-9*eye(size(S_cov));

%% =========================
%% UPDATE
%% =========================
K = Pxz / S_cov;

x = x_pred + K*(z_used - z_pred_used);
Pk = P_pred - K*S_cov*K&apos;;
Pk = (Pk + Pk&apos;)/2 + 1e-9*eye(n);

%% =========================
%% OUTPUT
%% =========================
xhat = x;
P = Pk;
dxdt = dxdt_model;

innovation = zeros(length(z),1);
innovation(valid_idx) = z_used - z_pred_used;

K_out = zeros(n,length(z));
K_out(:,valid_idx) = K;

S_out = zeros(length(z));
S_out(valid_idx,valid_idx) = S_cov;

z_pred_out = z_pred;

end</P>
      </eml>
    </state>
    <data SSID="7" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
