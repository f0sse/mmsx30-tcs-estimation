<?xml version="1.0" encoding="utf-8"?>
<chart id="429">
  <P Name="name">TruckMaker/Tractor_Subsystem /EKF_ONE_TRACK</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">429</P>
  <P Name="ssIdHighWaterMark">12</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">30</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">EKF_Bicycle_Full_NoBias</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">429</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P] = EKF_Bicycle_Full_NoBias(z, u, Q, R, Ts)
% EKF for One-Track / Bicycle Model (No IMU Bias)
% States: x = [vx; vy; r; Cf; Cr]
% Measurements: z = [ax; ay; vx; vy; r; wL; wR]

%% ---------------- Persistent safe initialization ----------------
persistent x Pk initialized

% Säker initialisering
if isempty(x)
    x = [15; 0; 0.05; 2e4; 2e4];  % vx, vy, r, Cf, Cr
end

if isempty(Pk)
    Pk = diag([1 1 0.05 4e4 4e4].^2); % 5x5
end

if isempty(initialized)
    initialized = true;
end


%% ---------------- Vehicle parameters ----------------

m  = 6800;        %  mass
g  = 9.82;        % gravity contanst   
Jz = 12994.917;   % yaw interia
Rw = 0.49;          % wheel radius
width = 2.49;       % track width

p_cog  = [3.473; 0; 0.925];
p_fax  = [4.520; 0; 0.490];

p_rax  = [0.950; 0; 0.490];
p_imu  = [3.600; 0; 1.000];

lf = abs(p_fax(1)-p_cog(1));   % front CoG distance
lr = abs(p_cog(1)-p_rax(1));   % rear CoG distance
L  = lf + lr;
h  = p_cog(3);

Rfax = p_fax - p_imu; Rfax(3) = -p_imu(3);
Rrax = p_rax - p_imu; Rrax(3) = -p_imu(3);
Rcog = p_cog - p_imu;

%% ---------------- Inputs ----------------
delta = u(1);                             % Average steering Angle (FL +FR)/2
T_rl  = u(2);                             % torque RL  
T_rr  = u(3);                             %torque RR
Rwheel = 0.49;                            % wheel radius
Fx_vehicle = (T_rl + T_rr)/Rwheel;        % longitudinal force

%% ---------------- States ----------------
vx = x(1); vy = x(2); r = x(3); Cf = x(4); Cr= x(5);

Rotf = [ cos(delta)     -sin(delta)     0;
         sin(delta)      cos(delta)     0;
             0              0           1];

v_cog = [vx; vy; 0];
omega = [0;0;r];

% Contact patch velocities
vf = Rotf.&apos; * (v_cog + cross(omega,Rfax));
vr = v_cog + cross(omega,Rrax);

alpha_f = atan2(vf(2), max(abs(vf(1)),0.1));
alpha_r = atan2(vr(2), max(abs(vr(1)),0.1));

% Longitudinal accel estimate to compute the vertikel forces
dvx_temp = Fx_vehicle/m + vy*r;

% Normal forces
Ffz = m*g*lr/L - m*dvx_temp*h/L;
Frz = m*g*lf/L + m*dvx_temp*h/L;

% Tire forces
Fy_f = Cf * alpha_f * Ffz;
Fy_r = Cr * alpha_r * Frz;

% Full dynamics 
dvx = (Fx_vehicle - Fy_f*sin(delta))/m + vy*r;
dvy = (Fy_f*cos(delta) + Fy_r)/m - vx*r;
dr  = (lf*Fy_f*cos(delta) - lr*Fy_r)/Jz;

% State propagation
xdot = [dvx; dvy; dr; 0; 0];
x_pred = x + Ts*xdot;

%% ---------------- Jacobian F ----------------
F= zeros(5,5);
F(1,:) = [                                1 - (Cf*Ts*sin(delta)*(vy + lf*r))/(m*vx^2),              Ts*(r + (Cf*sin(delta))/(m*vx)),                   Ts*(vy + (Cf*lf*sin(delta))/(m*vx)),    -(Ts*sin(delta)*(delta - (vy + lf*r)/vx))/m,                            0];
F(2,:) = [  -Ts*(r - ((Cr*(vy - lr*r))/vx^2 + (Cf*cos(delta)*(vy + lf*r))/vx^2)/m),      1 - (Ts*(Cr/vx + (Cf*cos(delta))/vx))/m,    -Ts*(vx - ((Cr*lr)/vx - (Cf*lf*cos(delta))/vx)/m),     (Ts*cos(delta)*(delta - (vy + lf*r)/vx))/m,    -(Ts*(vy - lr*r))/(m*vx)];
F(3,:) = [-(Ts*((Cr*lr*(vy - lr*r))/vx^2 - (Cf*lf*cos(delta)*(vy + lf*r))/vx^2))/Jz, (Ts*((Cr*lr)/vx - (Cf*lf*cos(delta))/vx))/Jz, 1 - (Ts*((Cf*cos(delta)*lf^2)/vx + (Cr*lr^2)/vx))/Jz, (Ts*lf*cos(delta)*(delta - (vy + lf*r)/vx))/Jz, (Ts*lr*(vy - lr*r))/(Jz*vx)];
F(4,:) = [                                                                            0,                                              0,                                                      0,                                                 1,                            0];
F(5,:) = [                                                                            0,                                              0,                                                      0,                                                 0,                            1];


%% ---------------- Covariance prediction ----------------
P_pred = F*Pk*F&apos; + Q;

%% ---------------- Measurement model ----------------
ax_hat = dvx -  vy*r;                % longitudinal accel
ay_hat = dvy + vx*r;                % lateral accel
%vx_hat = vx;
%vy_hat = vy;
%r_hat  = r;
%wL_hat = (vx - width/2 * r)/Rw;
%wR_hat = (vx + width/2 * r)/Rw;

a_cog = [ax_hat; ay_hat; 0];
alpha_vec = [0;0;dr];

% Transform to IMU
a_imu = a_cog - cross(omega, cross(omega,Rcog))- cross(alpha_vec,Rcog);
v_imu = v_cog + cross(omega,Rcog);

z_hat = [a_imu(1:2);
         v_imu(1:2);
         alpha_vec(3);
         omega(3)];

%z_hat = [ax_hat; ay_hat; vx_hat; vy_hat; dr_hat r_hat; wL_hat; wR_hat];

%% ---------------- Measurement Jacobian H ----------------
H = zeros(size(z_hat,1),size(x,1));

%H = zeros(7,5);
H(1,:) = [                               1 - (Cf*Ts*sin(delta)*(vy + lf*r))/(m*vx^2),         Ts*(r + (Cf*sin(delta))/(m*vx)) - r,                      Ts*(vy + (Cf*lf*sin(delta))/(m*vx)) - vy, -(Ts*sin(delta)*(delta - (vy + lf*r)/vx))/m,                            0];
H(2,:) = [-Ts*(r - ((Cr*(vy - lr*r))/vx^2 + (Cf*cos(delta)*(vy + lf*r))/vx^2)/m), 1 - (Ts*(Cr/vx + (Cf*cos(delta))/vx))/m, vx - Ts*(vx - ((Cr*lr)/vx - (Cf*lf*cos(delta))/vx)/m),  (Ts*cos(delta)*(delta - (vy + lf*r)/vx))/m, -(Ts*(vy - lr*r))/(m*vx)];
H(3,:) = [                                                                             1,                                               0,                                                                 0,                                               0,            0];
H(4,:) = [                                                                             0,                                               1,                                                                 0,                                               0,            0];
H(5,:) = [                                                                             0,                                               0,                                                                 0,                                               0,            0];
H(6,:) = [                                                                             0,                                               0,                                                                 1,                                               0,            0];
%H(7,:) = [                                                                             1/Rw,                                            0,                                                     -width/(2*Rw),                                               0,            0];
%H(8,:) = [                                                                             1/Rw,                                            0,                                                      width/(2*Rw),                                               0,            0];

%% ---------------- EKF update ----------------
S = H*P_pred*H&apos; + R;
K = P_pred*H&apos;/(S + 1e-9*eye(size(S)));

x = x_pred + K*(z - z_hat);
Pk = P_pred - K*S*K&apos;;

%% ---------------- Output ----------------
xhat = x;
P = Pk;

end
</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
