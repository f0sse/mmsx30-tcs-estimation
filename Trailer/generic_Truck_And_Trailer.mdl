  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">AccelNoiseBlock</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">291</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function acc_meas = AccelNoiseBlock(acc_true)

Fs = 1000;

truth = acc_true;      % 1×3

[meas,~] = AccelNoise(truth,Fs);

acc_meas = meas;       % 3×1

end</P>
      </eml>
    </state>
    <data SSID="4" name="acc_true">
      <P Name="scope">INPUT_DATA</P>
      <props>
