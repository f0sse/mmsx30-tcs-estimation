__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_93.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="93">
  <P Name="name">TruckMaker/Two_TRack_Model/UKF_ONE_TRACK</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">93</P>
  <P Name="ssIdHighWaterMark">26</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">3</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_Bicycle</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">93</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [xhat, P] = UKF_Bicycle(z,u,Q,Ts)
% UKF for Bicycle model estimating Cf and Cr from IMU
% States: x = [vx_cog; vy_cog; r; Cf; Cr]
% Measurements z = [ax; ay; az; vx; vy; vz; rx; ry; rz; alphax; alphay; alphaz; wFL; wFR; wRL; wRR]
% Inputs u = [delta; T_rl; T_rr]

persistent x Pk
if isempty(x)
    x = [15; 0; 0.01; 4e4; 4e4]; 
end
if isempty(Pk)
    Pk = diag([1 1 0.01 1e4 1e4]);
end

%% -----------------------------------------------------------------------
% Vehicle parameters
%% -----------------------------------------------------------------------
m  = 7000;
g  = 9.82;
Jz = 14232.357; % yaw inertia

% Geometry
p_cog  = [3.401; 0; 0.913];
p_fax  = [4.520; 0; 0.490];
p_rax  = [0.950; 0; 0.490];
p_imu  = [3.600; 0; 1.000];

lf = abs(p_fax(1)-p_cog(1));
lr = abs(p_cog(1)-p_rax(1));
L  = lf + lr;
h  = p_cog(3);

Rfax = p_fax - p_imu; Rfax(3) = -p_imu(3);
Rrax = p_rax - p_imu; Rrax(3) = -p_imu(3);
Rcog = p_cog - p_imu;

%% -----------------------------------------------------------------------
% Measurements
%% -----------------------------------------------------------------------
a_meas     = z(1:3);
v_meas     = z(4:6);
omega_meas = z(7:9);
alpha_meas = z(10:12);
wheels     = z(13:16);

%% -----------------------------------------------------------------------
% Inputs
%% -----------------------------------------------------------------------
delta = u(1);
T_rl  = u(2);
T_rr  = u(3);

Rwheel = 0.49;
Fx_vehicle = (T_rl + T_rr)/Rwheel;

%% -----------------------------------------------------------------------
% UKF parameters
%% -----------------------------------------------------------------------
n = length(x);
W0 = 1 - n/3;
Wi = (1 - W0)/(2*n);
gamma = sqrt(n/(1-W0));

S = chol(Pk,&apos;lower&apos;);
X = zeros(n,2*n+1);
X(:,1) = x;
for i=1:n
    X(:,i+1)   = x + gamma*S(:,i);
    X(:,i+1+n) = x - gamma*S(:,i);
end

%% -----------------------------------------------------------------------
% PROPAGATION (Linear tire model)
%% -----------------------------------------------------------------------
X_pred = zeros(n,2*n+1);

for k=1:2*n+1
    vx  = X(1,k);
    vy  = X(2,k);
    r   = X(3,k);
    Cf  = X(4,k);
    Cr  = X(5,k);

    Rotf = [ cos(delta), -sin(delta), 0;
             sin(delta),  cos(delta), 0;
                      0,           0, 1];

    v_cog = [vx; vy; 0];
    omega = [0;0;r];

    % Slip angles at contact points
    vf = Rotf.&apos; * (v_cog + cross(omega,Rfax));
    vr = v_cog + cross(omega,Rrax);

    alpha_f = atan2(vf(2), max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2), max(abs(vr(1)),0.1));

    % Lateral forces from state stiffness
    Fy_f = -Cf * alpha_f;
    Fy_r = -Cr * alpha_r;

    % Planar dynamics
    dvx = (Fx_vehicle + Fy_f*sin(delta))/m + vy*r;
    dvy = (Fy_f*cos(delta) + Fy_r)/m - vx*r;
    dr  = (lf*Fy_f*cos(delta) - lr*Fy_r)/Jz;

    X_pred(:,k) = [vx + Ts*dvx;
                   vy + Ts*dvy;
                   r  + Ts*dr;
                   Cf;
                   Cr];
end

% Predicted mean
x_pred = W0*X_pred(:,1);
for k=2:2*n+1
    x_pred = x_pred + Wi*X_pred(:,k);
end

% Predicted covariance
P_pred = Q*Ts;
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    P_pred = P_pred + w*(dx*dx&apos;);
end

%% -----------------------------------------------------------------------
% MEASUREMENT MODEL (Force-based using IMU)
%% -----------------------------------------------------------------------
Z = zeros(length(z),2*n+1);

for k=1:2*n+1
    vx  = X_pred(1,k);
    vy  = X_pred(2,k);
    r   = X_pred(3,k);
    Cf  = X_pred(4,k);
    Cr  = X_pred(5,k);

    v_cog = [vx; vy; 0];
    omega_vec = [0;0;r];

    % --- Normal forces
    ax = a_meas(1);
    ay = a_meas(2);
    rdot = alpha_meas(3);

    Ffz = m*g*lr/L - m*ax*h/L;
    Frz = m*g*lf/L + m*ax*h/L;

    % Lateral forces from IMU (Newton-Euler)
    Ffy = (Jz*rdot + m*ay*lr)/(L*cos(delta));
    Fry = (m*ay*lf - Jz*rdot)/L;

    % Compute slip angles at contact points
    Rotf = [ cos(delta), -sin(delta), 0;
             sin(delta),  cos(delta), 0;
                      0,           0, 1];
    vf = Rotf.&apos; * (v_cog + cross(omega_vec,Rfax));
    vr = v_cog + cross(omega_vec,Rrax);

    alpha_f = atan2(vf(2), max(abs(vf(1)),0.1));
    alpha_r = atan2(vr(2), max(abs(vr(1)),0.1));

    % Normalize to get new Cf/Cr for measurement update
    Cf_meas = Cf;
    Cr_meas = Cr;
    if abs(alpha_f)&gt;0.01, Cf_meas = Ffy/(alpha_f*Ffz); end
    if abs(alpha_r)&gt;0.01, Cr_meas = Fry/(alpha_r*Frz); end

    % CoG acceleration
    dvx = Fx_vehicle/m;
    dvy = (Ffy + Fry)/m;
    dr  = (lf*Ffy - lr*Fry)/Jz;

    a_cog = [dvx; dvy; 0];
    alpha_vec = [0;0;dr];

    % Rigid body transform to IMU
    a_imu = a_cog ...
        - cross(omega_vec, cross(omega_vec, Rcog)) ...
        - cross(alpha_vec, Rcog);

    v_imu = v_cog + cross(omega_vec,Rcog);

    Z(:,k) = [a_imu;
              v_imu;
              omega_vec;
              alpha_vec;
              wheels];
end

% Measurement mean
z_pred = W0*Z(:,1);
for k=2:2*n+1
    z_pred = z_pred + Wi*Z(:,k);
end

% Measurement covariance
S_cov = 1e-6*eye(length(z));
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dz = Z(:,k) - z_pred;
    S_cov = S_cov + w*(dz*dz&apos;);
end

% Cross covariance
Pxz = zeros(n,length(z));
for k=1:2*n+1
    w = (k==1)*W0 + (k&gt;1)*Wi;
    dx = X_pred(:,k) - x_pred;
    dz = Z(:,k) - z_pred;
    Pxz = Pxz + w*(dx*dz&apos;);
end

% UKF update
K = Pxz / S_cov;
x = x_pred + K*(z - z_pred);
Pk = P_pred - K*S_cov*K&apos;;

xhat = x;
P = Pk;

end




























% function [xhat, P, Ffy, Fry] = UKF_Bicycle(z, u, Q, R, Ts)
% % UKF for Bicycle model (DISCRETE, SAFE)
% % States:      x = [vx; vy; wz; Cf; Cr]
% % Measurements z = [ax; ay; vx; vy; wz; wL; wR]
% 
% %% ---------- Persistent ----------
% persistent x Pk
% if isempty(x)
%     x  = [10; 0; 0.05; 6e4; 6e4];          % initial state
%     Pk = diag([1 1 0.01 1e6 1e6]);         % initial covariance
% end
% 
% n = 5;           % state dimension
% m = length(z);   % measurement dimension
% 
% %% ---------- UKF parameters ----------
% alpha = 1e-2;
% beta  = 2;
% kappa = 0;
% lambda = alpha^2*(n+kappa) - n;
% 
% %% ---------- Sigma points ----------
% S = chol((n+lambda)*Pk,&apos;lower&apos;);
% X = zeros(n,2*n+1);
% X(:,1) = x;
% for i=1:n
%     X(:,i+1)   = x + S(:,i);
%     X(:,i+1+n) = x - S(:,i);
% end
% 
% %% ---------- Weights ----------
% Wm = [lambda/(n+lambda), repmat(1/(2*(n+lambda)),1,2*n)];
% Wc = Wm;
% Wc(1) = Wc(1) + (1-alpha^2+beta);
% 
% %% =========================================================
% %% 1) PREDICTION
% X_pred = zeros(n,2*n+1);
% for i=1:2*n+1
%     X_pred(:,i) = BicycleStep(X(:,i), u, Ts);
% end
% 
% x_pred = X_pred * Wm&apos;;
% 
% P_pred = Q;
% for i=1:2*n+1
%     dx = X_pred(:,i) - x_pred;
%     P_pred = P_pred + Wc(i)*(dx*dx&apos;);
% end
% 
% %% =========================================================
% %% 2) MEASUREMENT
% Zsig = zeros(m,2*n+1);
% for i=1:2*n+1
%     Zsig(:,i) = BicycleMeasurement(X_pred(:,i), u);
% end
% 
% z_pred = Zsig * Wm&apos;;
% 
% Pzz = R;
% Pxz = zeros(n,m);
% for i=1:2*n+1
%     dz = Zsig(:,i) - z_pred;
%     dx = X_pred(:,i) - x_pred;
%     Pzz = Pzz + Wc(i)*(dz*dz&apos;);
%     Pxz = Pxz + Wc(i)*(dx*dz&apos;);
% end
% 
% %% ---------- Update ----------
% K = Pxz / Pzz;
% 
% x  = x_pred + K*(z - z_pred);
% Pk = P_pred - K*Pzz*K&apos;;
% 
% xhat = x;
% P    = Pk;
% 
% %% ---------- Forces output ----------
% [~, Ffy, Fry] = BicycleStep(x, u, Ts);
% 
% end
% 
% function [x_next, Ffy, Fry] = BicycleStep(x, u, Ts)
% 
% vx = x(1); vy = x(2); wz = x(3);
% Cf = x(4); Cr = x(5);
% 
% m  = 7000;
% Jz = 14232.357;
% lf = 1.12;
% lr = 2.451;
% Rw = 0.5;
% 
% delta = u(1);
% Tdrv  = u(2);
% 
% vx_eff = max(abs(vx),3);
% 
% alpha_f = (vy + lf*wz)/vx_eff - delta;
% alpha_r = (vy - lr*wz)/vx_eff;
% 
% Ffy = -Cf*alpha_f;
% Fry = -Cr*alpha_r;
% Frx = Tdrv / Rw;
% 
% dvx = (Frx - Ffy*sin(delta))/m + vy*wz;
% dvy = (Ffy*cos(delta) + Fry)/m - vx*wz;
% dwz = (lf*Ffy*cos(delta) - lr*Fry)/Jz;
% 
% x_next = [
%     vx + Ts*dvx;
%     vy + Ts*dvy;
%     wz + Ts*dwz;
%     Cf;
%     Cr
% ];
% end
% 
% function zhat = BicycleMeasurement(x, u)
% 
% vx = x(1); vy = x(2); wz = x(3);
% Cf = x(4); Cr = x(5);
% 
% m  = 7000;
% lf = 1.12;
% lr = 2.45;
% Rw = 0.5;
% track = 2.49;
% 
% vx_eff = max(abs(vx),3);
% delta = u(1);
% Tdrv=u(2);
% 
% alpha_f = (vy + lf*wz)/vx_eff - delta;
% alpha_r = (vy - lr*wz)/vx_eff;
% 
% Ffy = -Cf*alpha_f;
% Fry = -Cr*alpha_r;
% Frx = Tdrv / Rw;
% 
% %dvx = (-Ffy*sin(delta) + vy*wz)/m;
% %dvy = (Ffy*cos(delta) + Fry - vx*wz)/m;
% dvx = (Frx - Ffy*sin(delta))/m + vy*wz;
% dvy = (Ffy*cos(delta) + Fry)/m - vx*wz;
% 
% ax = dvx - vy*wz;
% ay = dvy + vx*wz;
% 
% %wL = (vx - track/2*wz)/Rw;
% wL=vx/Rw;
% %wR = (vx + track/2*wz)/Rw;
% 
% %zhat = [ax; ay; wz; wL];
% zhat = [ax; ay; vx; vy; wz; wL];
% end
% 
% 






































% function [xhat, P, Ffy, Fry] = UKF_Bicycle(z, u, Q, R, Ts)
% % UKF for Bicycle model
% % States: x = [vx vy wz Cf Cr]&apos;
% % Measurements: z = [ax ay vx vy wz wL wR]
% 
% persistent x Pk
% if isempty(x)
%     x = [10; 0.1; 0.05; 6e4; 6e4];  % initial guess
%     Pk  = diag([0.1 0.1 0.01 1e4 1e4]); 
% end
% 
% n = length(x); % state dimension
% m = length(z); % measurement dimension
% 
% % UKF parameters
% alpha = 1e-3;
% beta = 2;
% kappa = 0;
% lambda = alpha^2*(n+kappa)-n;
% 
% % Sigma points
% X = zeros(n, 2*n+1);
% S = chol((n+lambda)*Pk,&apos;lower&apos;);
% X(:,1) = x;
% for i=1:n
%     X(:,i+1)   = x + S(:,i);
%     X(:,i+1+n) = x - S(:,i);
% end
% 
% % Weights
% Wm = [lambda/(n+lambda) repmat(1/(2*(n+lambda)),1,2*n)];
% Wc = Wm;
% Wc(1) = Wc(1) + (1-alpha^2+beta);
% 
% %% Prediction for each sigma point
% X_pred = zeros(n,2*n+1);
% for i=1:2*n+1
%     X_pred(:,i) = BicycleDynamics(X(:,i), u, Ts);
% end
% 
% % Predicted state
% x_pred = X_pred*Wm&apos;;
% 
% % Predicted covariance
% P_pred = Q;
% for i=1:2*n+1
%     dx = X_pred(:,i)-x_pred;
%     P_pred = P_pred + Wc(i)*(dx*dx&apos;);
% end
% 
% %% Measurement prediction
% Z_sigma = zeros(m,2*n+1);
% for i=1:2*n+1
%     Z_sigma(:,i) = BicycleMeasurement(X_pred(:,i), u);
% end
% 
% z_pred = Z_sigma*Wm&apos;;
% 
% P_zz = R;
% P_xz = zeros(n,m);
% for i=1:2*n+1
%     dz = Z_sigma(:,i) - z_pred;
%     dx = X_pred(:,i) - x_pred;
%     P_zz = P_zz + Wc(i)*(dz*dz&apos;);
%     P_xz = P_xz + Wc(i)*(dx*dz&apos;);
% end
% 
% % Kalman gain
% K = P_xz / P_zz;
% 
% % State update
% x = x_pred + K*(z - z_pred);
% Pk = P_pred - K*P_zz*K&apos;;
% 
% xhat = x;
% P=Pk;
% % Optional: compute Ffy/Fry from predicted state
% [~, Ffy, Fry] = BicycleDynamics(x, u, Ts);
% 
% end
% 
% %% =========================================================
% function [xdot, Ffy, Fry] = BicycleDynamics(x, u, Ts)
% % Bicycle model dynamics
% vx = x(1); vy = x(2); wz = x(3);
% Cf = x(4); Cr = x(5);
% 
% m  = 7000;
% Jz = 14232.357;
% lf = 1.119;
% lr = 2.451;
% Rw = 0.49;
% 
% vx_eff = max(abs(vx), 3);
% 
% delta  = u(1);
% Tdrive = u(2);
% 
% alpha_f = (vy + lf*wz)/vx_eff - delta;
% alpha_r = (vy - lr*wz)/vx_eff;
% 
% Ffy = -Cf*alpha_f;
% Fry = -Cr*alpha_r;
% 
% Frx = Tdrive / Rw;
% 
% dvx = (Frx - Ffy*sin(delta))/m + vy*wz;
% dvy = (Ffy*cos(delta) + Fry)/m - vx*wz;
% dwz = (lf*Ffy*cos(delta) - lr*Fry)/Jz;
% 
% dCf = 0; dCr = 0;
% 
% xdot = [vx + dvx*Ts;
%         vy + dvy*Ts;
%         wz + dwz*Ts;
%         Cf;
%         Cr];
% end
% 
% %% =========================================================
% function z_hat = BicycleMeasurement(x, u)
% % Measurement model
% vx = x(1); vy = x(2); wz = x(3);
% Cf = x(4); Cr = x(5);
% 
% m  = 7000;
% lf = 1.119;
% lr = 2.451;
% Rw = 0.49;
% track = 2.49;
% 
% alpha_f = (vy + lf*wz)/vx - u(1);
% alpha_r = (vy - lr*wz)/vx - 0;
% 
% Ffy = -Cf*alpha_f;
% Fry = -Cr*alpha_r;
% 
% dvx = (0 - Ffy*sin(u(1)) + vy*wz)/m;
% dvy = (Ffy*cos(u(1)) + Fry - vx*wz)/m;
% 
% ax_hat = dvx - vy*wz;
% ay_hat = dvy + vx*wz;
% 
% vx_hat = vx;
% vy_hat = vy;
% wz_hat = wz;
% 
% wL_hat = (vx - track*wz)/Rw;
% wR_hat = (vx + track*wz)/Rw;
% 
% z_hat = [ax_hat; ay_hat; vx_hat; vy_hat; wz_hat; wL_hat; wR_hat];
% end
</P>
      </eml>
    </state>
    <data SSID="6" name="z">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="u">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="xhat">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="Q">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="Ts">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="P">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
