  <eml>
    <P Name="name">imu_vel_noise</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">404</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function vel_meas = imu_vel_noise(truth)
    

sigma = 0.05; % m/s^2 (tune later)

vel_meas = truth + sigma * randn(size(truth));


end</P>
      </eml>
    </state>
    <data SSID="4" name="truth">
